---
// About.astro — Bio, headshot, domains, social links

const domains = [
  "Carbon &amp; ESG infrastructure",
  "Workflow &amp; audit systems",
  "Identity &amp; authority models",
  "Token economy &amp; mechanism design",
  "Supply chain provenance",
  "Protocol architecture",
  "Enterprise data systems",
  "AI coordination layers",
];
---

<section id="about" class="section-padding px-6">
  <div class="max-w-6xl mx-auto">

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-16 lg:gap-24">

      <!-- Left column: Bio -->
      <div class="lg:col-span-3 reveal">
        <p class="text-signal text-xs font-semibold tracking-[0.3em] uppercase mb-4">
          About
        </p>
        <h2 class="text-gradient text-3xl md:text-4xl font-display font-bold tracking-tight mb-8 leading-tight">
          The architecture beneath trust, workflow, authority, and evidence
        </h2>

        <div class="space-y-5 text-text-secondary text-base leading-relaxed">
          <p>
            As CTO and architect at <a href="https://dovu.ai" target="_blank" rel="noopener" class="text-signal hover:underline">DOVU</a>, I designed the core architecture for an audit trail and workflow platform now serving programs managing over $1B in value. More recently, I designed <a href="https://authority.dovu.ai" target="_blank" rel="noopener" class="text-signal hover:underline">Authority Trail</a> &mdash; a protocol for provable authority in carbon markets.
          </p>
          <p>
            I design token economies with the same mindset I bring to infrastructure: make incentives explicit, understand the pressure points, and build for real world behaviour. Flywheels, demand sinks, issuance pressure, and the structural conditions that determine whether a token can hold long term relevance inside a network.
          </p>
          <p>
            My edge is the combination: systems architecture, trust and provenance thinking, identity and authority design, workflow and process modelling, protocol thinking, token economy design, and commercial reality. That combination is rare.
          </p>
        </div>

        <!-- Social links -->
        <div class="flex items-center gap-5 mt-8">
          <a href="https://github.com/mattsmithies" target="_blank" rel="noopener" class="text-text-tertiary text-sm hover:text-signal transition-colors">GitHub</a>
          <a href="https://linkedin.com/in/mattsmithies" target="_blank" rel="noopener" class="text-text-tertiary text-sm hover:text-signal transition-colors">LinkedIn</a>
          <a href="https://dovu.ai" target="_blank" rel="noopener" class="text-text-tertiary text-sm hover:text-signal transition-colors">DOVU</a>
        </div>
      </div>

      <!-- Right column: Photo + Domains -->
      <div class="lg:col-span-2 reveal space-y-6">

        <!-- Headshot: drop your image at public/headshot.jpg -->
        <div class="glass-card p-2 overflow-hidden">
          <img
            src="/headshot.jpg"
            alt="Matt Smithies"
            class="w-full aspect-[3/4] object-cover object-top rounded-xl"
            loading="lazy"
            onerror="this.parentElement.style.display='none'"
          />
        </div>

        <!-- Domains -->
        <div class="glass-card p-8">
          <h3 class="text-text-primary font-display font-semibold text-sm tracking-[0.15em] uppercase mb-6">
            Domains
          </h3>
          <ul class="space-y-0">
            {domains.map((domain) => (
              <li class="py-3 border-b border-border last:border-0">
                <span class="text-text-secondary text-sm" set:html={domain} />
              </li>
            ))}
          </ul>
        </div>

      </div>

    </div>
  </div>
</section>
