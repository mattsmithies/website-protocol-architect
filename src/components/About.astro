---
// About.astro — Bio, headshot, domains, social links

const domains = [
  "Carbon and environmental infrastructure",
  "Workflow and audit systems",
  "Identity and authority models",
  "Token economy and mechanism design",
  "Supply chain provenance",
  "Protocol architecture",
  "Enterprise data systems",
  "AI coordination and memory layers",
];
---

<section id="about" class="section-padding px-6">
  <div class="max-w-6xl mx-auto">

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-16 lg:gap-24">

      <!-- Left column: Bio -->
      <div class="lg:col-span-3 reveal">
        <p class="text-signal text-xs font-semibold tracking-[0.3em] uppercase mb-4">
          About
        </p>
        <h2 class="text-gradient text-3xl md:text-4xl font-display font-bold tracking-tight mb-8 leading-tight">
          The architecture beneath trust, authority, workflow, and incentives
        </h2>

        <div class="space-y-5 text-text-secondary text-base leading-relaxed">
          <p>
            I design systems for environments where trust cannot remain implicit.
          </p>
          <p>
            That includes authority models, provenance, workflow execution, token economies, and the underlying structures that allow complex systems to hold together over time.
          </p>
          <p>
            My work sits between long horizon architecture and practical delivery. I think in decade scale systems, but I break them down into annual stages, clear primitives, and execution paths that teams can actually ship.
          </p>
          <p>
            My edge is the combination: systems architecture, authority design, workflow modelling, provenance thinking, protocol strategy, token economy design, and commercial reality. Most teams split those concerns across different people and end up with gaps between them. I work across the whole model.
          </p>
        </div>

        <!-- Social links -->
        <div class="flex items-center gap-5 mt-8">
          <a href="https://github.com/mattsmithies" target="_blank" rel="noopener" class="text-text-tertiary text-sm hover:text-signal transition-colors">GitHub</a>
          <a href="https://linkedin.com/in/mattsmithies" target="_blank" rel="noopener" class="text-text-tertiary text-sm hover:text-signal transition-colors">LinkedIn</a>
          <a href="https://dovu.ai" target="_blank" rel="noopener" class="text-text-tertiary text-sm hover:text-signal transition-colors">DOVU</a>
        </div>
      </div>

      <!-- Right column: Photo + Domains -->
      <div class="lg:col-span-2 reveal space-y-6">

        <!-- Headshot: drop your image at public/headshot.jpg -->
        <div class="glass-card p-2 overflow-hidden relative">
          <img
            src="/headshot.jpg"
            alt="Matt Smithies"
            class="w-full aspect-[3/4] object-cover object-top rounded-xl brightness-[0.45] contrast-[1.1] saturate-[0.3]"
            loading="lazy"
            onerror="this.parentElement.style.display='none'"
          />
          <!-- Violet overlay tint -->
          <div class="absolute inset-0 rounded-xl bg-gradient-to-b from-signal/10 via-transparent to-void/60 mix-blend-screen pointer-events-none"></div>
        </div>

        <!-- Domains -->
        <div class="glass-card p-8">
          <h3 class="text-text-primary font-display font-semibold text-sm tracking-[0.15em] uppercase mb-6">
            Domains
          </h3>
          <ul class="space-y-0">
            {domains.map((domain) => (
              <li class="py-3 border-b border-border last:border-0">
                <span class="text-text-secondary text-sm" set:html={domain} />
              </li>
            ))}
          </ul>
        </div>

      </div>

    </div>
  </div>
</section>
