---
// Responses.astro — Public responses, consultation submissions, and technical interventions
import { getCollection } from 'astro:content';

const responses = (await getCollection('responses')).sort((a, b) => a.data.order - b.data.order);
---

<section id="responses" class="section-padding px-6">
  <div class="max-w-6xl mx-auto">

    <div class="reveal mb-16 md:mb-20">
      <p class="text-signal text-xs font-semibold tracking-[0.3em] uppercase mb-4">
        Responses
      </p>
      <h2 class="text-gradient text-3xl md:text-4xl lg:text-5xl font-display font-bold tracking-tight mb-6">
        Public responses
      </h2>
      <p class="text-text-secondary text-lg max-w-2xl leading-relaxed">
        Public responses, consultation submissions, and short technical interventions on live questions in identity, authority, verification, and public digital infrastructure.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
      {responses.map((response, i) => (
        <a
          href={`/responses/${response.id}`}
          class="reveal glass-card p-7 group hover:border-signal/20 transition-all duration-500 flex flex-col"
          style={`transition-delay: ${i * 60}ms`}
        >
          <span class="text-signal/50 text-xs font-semibold tracking-[0.2em] uppercase mb-4 block group-hover:text-signal/80 transition-colors">
            {response.data.date}
          </span>
          <h3 class="text-text-primary font-display font-bold text-lg tracking-tight mb-3 group-hover:text-signal transition-colors duration-300">
            {response.data.title}
          </h3>
          <p class="text-text-tertiary text-sm leading-relaxed mb-6">
            {response.data.summary}
          </p>
          <div class="mt-auto flex items-center gap-2 text-text-tertiary group-hover:text-signal text-xs font-medium transition-colors duration-300">
            <span>Read</span>
            <svg class="w-3 h-3 group-hover:translate-x-1 transition-transform" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M2 6h8M7 3l3 3-3 3" />
            </svg>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>
