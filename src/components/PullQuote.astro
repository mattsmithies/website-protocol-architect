---
// PullQuote.astro — editorial pull quote for essay + response bodies.
// Fraunces italic display, oversized decorative opening mark, optional
// attribution. Invoke inside MDX or an .astro body:
//
//   <PullQuote by="— Matt Smithies">
//     The proof package, not the anchor, is the thing that survives.
//   </PullQuote>
//
// For markdown (.md) essays, this component can't be used inline —
// switch those essays to .mdx or drop the quote in the host .astro.

interface Props {
  by?: string;
  align?: 'left' | 'center';
}

const { by, align = 'left' } = Astro.props;
---

<figure class={`pull-quote reveal pull-quote--${align}`}>
  <span class="pull-quote-mark" aria-hidden="true">&ldquo;</span>
  <blockquote class="pull-quote-body">
    <slot />
  </blockquote>
  {by && (
    <figcaption class="pull-quote-attribution">{by}</figcaption>
  )}
</figure>

<style>
  .pull-quote {
    position: relative;
    margin: 3.5rem 0;
    padding: 0.5rem 0 0.5rem 2.5rem;
    border-left: 1px solid rgba(167, 139, 250, 0.35);
  }

  @media (min-width: 768px) {
    .pull-quote {
      margin: 4.5rem -2rem 4.5rem -2rem;
      padding-left: 3rem;
    }
  }

  .pull-quote--center {
    border-left: 0;
    padding-left: 0;
    text-align: center;
    max-width: 42rem;
    margin-inline: auto;
  }

  /* Oversized opening quote glyph — Fraunces display, gradient-filled,
     positioned as a decorative element above the body. */
  .pull-quote-mark {
    display: block;
    font-family: var(--font-editorial);
    font-variation-settings: "SOFT" 40, "opsz" 144;
    font-weight: 700;
    font-style: normal;
    font-size: 5.5rem;
    line-height: 0.6;
    letter-spacing: -0.05em;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, #c4b5fd 0%, #a78bfa 50%, #38bdf8 100%);
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    user-select: none;
  }

  .pull-quote--center .pull-quote-mark {
    margin-inline: auto;
  }

  /* The quote body — Fraunces italic, editorial scale, comfortable
     reading color against the dark bg. */
  .pull-quote-body {
    font-family: var(--font-editorial);
    font-variation-settings: "SOFT" 45, "opsz" 60;
    font-style: italic;
    font-weight: 450;
    font-size: 1.55rem;
    line-height: 1.35;
    letter-spacing: -0.005em;
    color: rgba(232, 232, 240, 0.92);
    margin: 0;
    text-wrap: pretty;
  }

  @media (min-width: 768px) {
    .pull-quote-body {
      font-size: 1.85rem;
      line-height: 1.3;
    }
  }

  @media (min-width: 1024px) {
    .pull-quote-body {
      font-size: 2.15rem;
    }
  }

  /* Attribution in mono — system voice, signals the source as metadata
     rather than prose. */
  .pull-quote-attribution {
    margin-top: 1.25rem;
    font-family: var(--font-system);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--color-text-tertiary);
    font-feature-settings: "ss01", "tnum";
  }

  .pull-quote-body :global(p) {
    margin: 0;
  }

  .pull-quote-body :global(p + p) {
    margin-top: 0.75rem;
  }
</style>
