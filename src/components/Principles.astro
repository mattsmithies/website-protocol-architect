---
const principles = [
  "Make authority explicit",
  "Make time first class",
  "Separate record from derived view",
  "Design for replayability",
  "Prefer clear primitives",
];
---

<section id="principles" class="section-padding px-6">
  <div class="max-w-6xl mx-auto">

    <!-- Section Header -->
    <div class="reveal mb-16 md:mb-20 text-center">
      <p class="text-signal text-xs font-semibold tracking-[0.3em] uppercase mb-4">
        Core principles
      </p>
    </div>

    <!-- Principles List -->
    <div class="max-w-3xl mx-auto">
      {principles.map((principle, index) => (
        <div
          class="reveal group flex items-center gap-6 py-5 border-b border-border hover:border-signal/30 transition-colors duration-500 last:border-0"
          style={`transition-delay: ${index * 60}ms`}
        >
          <span class="text-signal/50 text-sm font-mono tabular-nums group-hover:text-signal transition-colors">
            {String(index + 1).padStart(2, "0")}
          </span>
          <span class="text-text-primary text-lg md:text-xl font-display group-hover:text-signal transition-colors duration-300">
            {principle}
          </span>
        </div>
      ))}
    </div>

  </div>
</section>
