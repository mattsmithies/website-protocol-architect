---
// Writing.astro — Essay grid linking to /thinking/[slug]
import { getCollection } from 'astro:content';

const essays = (await getCollection('essays')).sort((a, b) => a.data.order - b.data.order);
---

<section id="essays" class="section-padding px-6">
  <div class="max-w-6xl mx-auto">

    <div class="reveal mb-16 md:mb-20">
      <p class="text-signal text-xs font-semibold tracking-[0.3em] uppercase mb-4">
        Essays
      </p>
      <h2 class="text-gradient text-3xl md:text-4xl lg:text-5xl font-display font-bold tracking-tight mb-6">
        Selected writing
      </h2>
      <p class="text-text-secondary text-lg max-w-2xl leading-relaxed">
        Essays on authority, replayability, workflow systems, signatures, provenance, and the structures that determine whether digital systems hold under real pressure.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {essays.map((essay, i) => (
        <a
          href={`/thinking/${essay.id}`}
          class="reveal glass-card p-7 group hover:border-signal/20 transition-all duration-500 flex flex-col"
          style={`transition-delay: ${i * 60}ms`}
        >
          <span class="text-signal/50 text-xs font-semibold tracking-[0.2em] uppercase mb-4 block group-hover:text-signal/80 transition-colors">
            {essay.data.category}
          </span>
          <h3 class="text-text-primary font-display font-bold text-lg tracking-tight mb-auto group-hover:text-signal transition-colors duration-300">
            {essay.data.title}
          </h3>
          <div class="mt-6 flex items-center gap-2 text-text-tertiary group-hover:text-signal text-xs font-medium transition-colors duration-300">
            <span>{essay.data.video ? 'Watch and read' : 'Read'}</span>
            <svg class="w-3 h-3 group-hover:translate-x-1 transition-transform" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M2 6h8M7 3l3 3-3 3" />
            </svg>
          </div>
        </a>
      ))}
    </div>

  </div>
</section>
