---
// Contact.astro — Collaboration CTA with scheduling link
---

<section id="contact" class="section-padding px-6">
  <div class="max-w-4xl mx-auto text-center">

    <p class="reveal text-signal text-xs font-semibold tracking-[0.3em] uppercase mb-4">
      Collaboration
    </p>

    <h2 class="reveal text-gradient text-3xl md:text-4xl lg:text-5xl font-display font-bold tracking-tight mb-6">
      Discuss a system
    </h2>

    <p class="reveal text-text-secondary text-lg leading-relaxed mb-12 max-w-xl mx-auto">
      If you are building infrastructure where trust, authority, evidence, or incentives matter &mdash; let's talk architecture.
    </p>

    <!-- Engagement types -->
    <div class="reveal flex flex-wrap justify-center gap-3 mb-12">
      <span class="text-xs text-text-tertiary px-4 py-2 rounded-full border border-border">Systems architecture &amp; protocol design</span>
      <span class="text-xs text-text-tertiary px-4 py-2 rounded-full border border-border">Trust, identity, authority &amp; provenance</span>
      <span class="text-xs text-text-tertiary px-4 py-2 rounded-full border border-border">Token economy &amp; mechanism design</span>
      <span class="text-xs text-text-tertiary px-4 py-2 rounded-full border border-border">Principal / Staff / Advisory roles</span>
    </div>

    <!-- Primary CTA: scheduling link (replace href when ready) -->
    <div class="reveal flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="mailto:matt@dovu.ai"
        class="glow-button magnetic inline-flex items-center gap-3 px-10 py-4 rounded-full text-sm tracking-wide"
      >
        Book an architecture review
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 8h10M10 4l4 4-4 4" />
        </svg>
      </a>
    </div>

    <!-- Replace mailto above with your Calendly/Cal.com link when ready -->

  </div>
</section>
