---
// Contact.astro — Minimal formal contact section
---

<section id="contact" class="section-padding px-6">
  <div class="max-w-4xl mx-auto text-center">

    <p class="reveal text-signal text-xs font-semibold tracking-[0.3em] uppercase mb-4">
      Contact
    </p>

    <p class="reveal text-text-secondary text-lg leading-relaxed mb-12 max-w-xl mx-auto">
      For policy, advisory, research, speaking, or technical review enquiries.
    </p>

    <div class="reveal flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="mailto:matt@dovu.earth?subject=Reaching%20out%20from%20your%20site"
        class="glow-button magnetic inline-flex items-center gap-3 px-10 py-4 rounded-full text-sm tracking-wide"
      >
        Get in touch
        <svg class="w-4 h-4" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <path d="M3 8h10M10 4l4 4-4 4" />
        </svg>
      </a>
    </div>

  </div>
</section>
