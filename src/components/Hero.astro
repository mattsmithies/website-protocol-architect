---
// Hero.astro — Cinematic hero with living force graph on the right
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden">

  <!-- Video background slot -->
  <div class="hero-video-container">
    <!-- Uncomment when video is ready:
    <video autoplay muted loop playsinline>
      <source src="/hero-video.mp4" type="video/mp4" />
    </video>
    -->
  </div>

  <!-- Force graph — lives on the right side of the hero -->
  <canvas
    id="hero-graph"
    class="absolute inset-0 w-full h-full z-[1] pointer-events-none"
    aria-hidden="true"
  ></canvas>

  <!-- Main content container -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-10 py-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">

      <!-- Left side — primary content -->
      <div class="lg:col-span-7">

        <!-- Name -->
        <h1 class="reveal text-gradient-hero text-5xl md:text-7xl lg:text-8xl font-display font-bold tracking-tighter leading-[1.05]">
          Matt Smithies
        </h1>

        <!-- Accent line -->
        <div class="reveal w-20 h-px bg-signal mt-6 mb-6" style="box-shadow: 0 0 12px rgba(167, 139, 250, 0.4);"></div>

        <!-- Title -->
        <p class="reveal text-xl md:text-2xl font-display text-signal font-medium tracking-wide">
          Protocol Architect
        </p>
        <p class="reveal text-sm md:text-base font-display text-text-tertiary tracking-wide mt-1">
          Currently building at DOVU
        </p>

        <!-- The line -->
        <p class="reveal text-text-primary text-lg md:text-xl font-display leading-snug max-w-lg mt-6">
          I design systems meant to hold over decades, then break them into practical annual stages that teams can actually deliver.
        </p>

        <!-- Positioning — tight, one line -->
        <p class="reveal text-text-tertiary text-sm md:text-base leading-relaxed max-w-md mt-4">
          Trust infrastructure, authority models, workflow systems, provenance, token economies, and the architecture beneath products where rules, evidence, and incentives have to become explicit.
        </p>

        <!-- CTAs -->
        <div class="reveal flex flex-col sm:flex-row gap-4 mt-10">
          <a href="#essays" class="glow-button magnetic px-8 py-4 rounded-full text-sm text-center">
            Read my essays
          </a>
          <a href="#contact" class="ghost-button magnetic px-8 py-4 rounded-full text-sm text-center">
            Book a conversation
          </a>
        </div>

      </div>

      <!-- Right side — the graph fills this space visually -->
      <div class="lg:col-span-5 hidden lg:block" aria-hidden="true">
        <div class="aspect-square"></div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 z-10">
    <div class="w-px h-8 bg-gradient-to-b from-signal/30 to-transparent animate-pulse"></div>
  </div>

</section>

<script>
  import { initForceGraph } from '../scripts/force-graph';

  const canvas = document.getElementById('hero-graph') as HTMLCanvasElement;
  if (canvas) initForceGraph(canvas);
</script>
