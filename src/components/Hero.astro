---
// Hero.astro — Cinematic hero with living force graph on the right
---

<section id="hero" class="relative min-h-screen flex items-center overflow-hidden">

  <!-- Video background slot -->
  <div class="hero-video-container">
    <!-- Uncomment when video is ready:
    <video autoplay muted loop playsinline>
      <source src="/hero-video.mp4" type="video/mp4" />
    </video>
    -->
  </div>

  <!-- Force graph — lives on the right side of the hero -->
  <canvas
    id="hero-graph"
    class="absolute inset-0 w-full h-full z-[1] pointer-events-none"
    aria-hidden="true"
  ></canvas>

  <!-- Main content container -->
  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 lg:px-10 py-24">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-8 items-center">

      <!-- Left side — primary content -->
      <div class="lg:col-span-7">

        <!-- System signature: role label in Plex Mono (terminal/protocol voice) -->
        <p class="reveal text-signal text-xs font-medium tracking-[0.3em] uppercase mb-5">
          Protocol Architect
        </p>

        <!-- Name — brand voice (IBM Plex Sans, tight tracking, soft gradient) -->
        <h1 class="reveal text-gradient-hero text-5xl md:text-7xl lg:text-8xl font-display font-bold tracking-tighter leading-[1.02]">
          Matt Smithies
        </h1>

        <!-- Accent line -->
        <div class="reveal w-20 h-px bg-signal mt-7 mb-7" style="box-shadow: 0 0 12px rgba(167, 139, 250, 0.4);"></div>

        <!-- Editorial signature: Fraunces italic, serif counterweight to the brand name above -->
        <p class="reveal font-editorial italic text-2xl md:text-3xl text-signal font-normal leading-snug max-w-xl" style="font-variation-settings: 'SOFT' 40, 'opsz' 72;">
          Writing on authority, replayability, digital identity, and trust infrastructure.
        </p>

        <!-- Positioning paragraph -->
        <p class="reveal text-text-secondary text-base md:text-lg leading-relaxed max-w-xl mt-7">
          I study how digital systems establish who is allowed to act, what can be verified later, and how trust survives dispute, scale, and time. My work focuses on authority, verification, auditability, workflow systems, and public digital infrastructure.
        </p>

        <!-- Affiliation meta line — system voice (Plex Mono), quiet -->
        <p class="reveal text-text-tertiary text-xs tracking-[0.15em] uppercase leading-relaxed max-w-xl mt-8">
          Currently at DOVU · Writing in personal capacity
        </p>

        <!-- CTAs -->
        <div class="reveal flex flex-col sm:flex-row gap-4 mt-10">
          <a href="#essays" class="glow-button magnetic px-8 py-4 rounded-full text-sm text-center">
            Read essays
          </a>
          <a href="#responses" class="ghost-button magnetic px-8 py-4 rounded-full text-sm text-center">
            View responses
          </a>
        </div>

      </div>

      <!-- Right side — the graph fills this space visually -->
      <div class="lg:col-span-5 hidden lg:block" aria-hidden="true">
        <div class="aspect-square"></div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-6 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1 z-10">
    <div class="w-px h-8 bg-gradient-to-b from-signal/30 to-transparent animate-pulse"></div>
  </div>

</section>

<script>
  import { initForceGraph } from '../scripts/force-graph';

  const canvas = document.getElementById('hero-graph') as HTMLCanvasElement;
  if (canvas) initForceGraph(canvas);
</script>
