---
// CaseStudies.astro — Selected work section with architecture case study cards

const caseStudies = [
  {
    label: "Trust Infrastructure",
    title: "DOVU OS — Verifiable execution for real world systems",
    problem:
      "Organisations running complex programmes need more than claims that work was done. They need proof that workflows were followed, roles were respected, and evidence was captured in a form that can be checked later.",
    primitive:
      "A system of record architecture where actions, role assignments, evidence, and state changes are preserved as replayable execution rather than lost across applications and process gaps.",
    approach:
      "Designed the core architecture for a workflow and audit platform serving carbon programmes, supply chains, and regulated processes. Role based authority, time bound permissions, evidence binding, and replayable state transitions.",
    outcome:
      "A long horizon trust infrastructure broken into deployable stages and now used across live programmes, proving the model under real operational pressure.",
    tags: [
      "Workflow Architecture",
      "Audit Trail",
      "Role-Based Authority",
      "Evidence Binding",
    ],
  },
  {
    label: "Protocol Design",
    title: "Authority Trail — Time bound authority made verifiable",
    problem:
      "Most systems can show that an action happened. Far fewer can prove that the actor was still entitled to take that action at the exact moment it occurred.",
    primitive:
      "A verifiable authority layer where grants, delegations, expiry, and revocation can be checked as time bound state rather than assumed from static roles.",
    approach:
      "Designed a protocol level system for provable authority in carbon markets, with explicit authority chains, time aware validity, and a verification layer that separates record from proof.",
    outcome:
      "A practical wedge into a much larger category problem: modelling authority as something that changes over time and still needs to remain replayable.",
    tags: [
      "Protocol Architecture",
      "Verifiable Credentials",
      "Market Infrastructure",
      "Provenance",
    ],
  },
  {
    label: "Token Economy & Mechanism Design",
    title: "Token and Incentive Architecture — Demand before narrative",
    problem:
      "Most token systems focus on issuance, story, and distribution before they create durable internal demand.",
    primitive:
      "An economic architecture grounded in structural demand, value routing, and reinforcement rather than cosmetic utility and emissions theatre.",
    approach:
      "Designed token flows as part of the system itself. Demand sinks, supply sinks, issuance pressure, behavioural incentives, market structure, and the conditions under which usage reinforces the network instead of leaking value out of it.",
    outcome:
      "A token model built to support long term network behaviour, not just launch conditions.",
    tags: [
      "Mechanism Design",
      "Token Economics",
      "Flywheel Design",
      "Demand & Supply Sinks",
      "Incentive Architecture",
    ],
  },
];
---

<section id="work" class="section-padding">
  <div class="max-w-6xl mx-auto px-6">

    <!-- Section Header -->
    <div class="reveal mb-16 md:mb-20">
      <p class="text-signal text-xs font-semibold tracking-[0.3em] uppercase mb-4">
        Selected Work
      </p>
      <h2 class="text-gradient text-3xl md:text-4xl lg:text-5xl font-display font-bold tracking-tight mb-6">
        Architecture in practice
      </h2>
      <p class="text-text-secondary text-lg max-w-2xl leading-relaxed">
        Systems where trust, authority, workflow, and incentives needed to be designed explicitly. Each case involved identifying a missing primitive, building the structure around it, and turning a long horizon problem into a practical delivery path.
      </p>
    </div>

    <!-- Case Study Cards -->
    <div class="space-y-8">
      {caseStudies.map((study) => (
        <div class="reveal glass-card p-8 md:p-10 lg:p-12 hover:border-signal/15 transition-all duration-500">

          <!-- Label row -->
          <div class="flex items-center gap-3 mb-6">
            <span class="w-2 h-2 rounded-full bg-signal" />
            <span class="text-signal text-xs font-semibold tracking-[0.2em] uppercase">
              {study.label}
            </span>
          </div>

          <!-- Title -->
          <h3 class="text-text-primary text-2xl md:text-3xl font-display font-bold tracking-tight mb-8">
            {study.title}
          </h3>

          <!-- Details grid -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-8">
            <div>
              <h4 class="text-text-tertiary text-xs font-semibold tracking-[0.2em] uppercase mb-3">
                Problem
              </h4>
              <p class="text-text-secondary text-sm leading-relaxed">
                {study.problem}
              </p>
            </div>
            <div>
              <h4 class="text-text-tertiary text-xs font-semibold tracking-[0.2em] uppercase mb-3">
                Missing Primitive
              </h4>
              <p class="text-text-secondary text-sm leading-relaxed">
                {study.primitive}
              </p>
            </div>
            <div>
              <h4 class="text-text-tertiary text-xs font-semibold tracking-[0.2em] uppercase mb-3">
                System Approach
              </h4>
              <p class="text-text-secondary text-sm leading-relaxed">
                {study.approach}
              </p>
            </div>
            <div>
              <h4 class="text-text-tertiary text-xs font-semibold tracking-[0.2em] uppercase mb-3">
                Outcome
              </h4>
              <p class="text-text-secondary text-sm leading-relaxed">
                {study.outcome}
              </p>
            </div>
          </div>

          <!-- Tags row -->
          <div class="flex flex-wrap gap-2">
            {study.tags.map((tag) => (
              <span class="text-xs text-text-tertiary px-3 py-1.5 rounded-full border border-border">
                {tag}
              </span>
            ))}
          </div>

        </div>
      ))}
    </div>

  </div>
</section>
