---
// Visual 4: Replaying authority at the moment of action
// Forensic reconstruction — slow, precise, mechanical
---

<div class="reveal my-12 md:my-16">
  <div class="rounded-2xl border border-border overflow-hidden" style="background: rgba(11,11,17,0.6);">
    <div class="p-6 md:p-8">

      <!-- Action card -->
      <div class="glass-card p-6 mb-6 max-w-md mx-auto text-center">
        <p class="text-text-tertiary text-xs tracking-[0.15em] uppercase mb-3">Action</p>
        <p class="font-display font-bold text-text-primary text-lg mb-2">Release funds for Project A</p>
        <div class="flex justify-center gap-6 text-sm text-text-tertiary mt-3">
          <span>Actor: <span class="text-text-secondary">Sarah Malik</span></span>
          <span>Time: <span class="text-text-secondary">21 May, 09:23</span></span>
        </div>
      </div>

      <!-- Replay button -->
      <div class="text-center mb-6">
        <button
          id="ar-replay-btn"
          class="ghost-button px-6 py-3 rounded-full text-sm font-display cursor-pointer"
          aria-label="Replay authority state to see if the action was valid at the time it occurred"
        >
          Replay authority state
        </button>
      </div>

      <!-- Reconstruction area -->
      <div id="ar-reconstruction" class="max-w-lg mx-auto space-y-3 transition-opacity duration-700" style="opacity: 0;" aria-live="polite" aria-label="Authority replay results">
      </div>

    </div>
  </div>
  <p class="text-text-tertiary text-xs mt-3 text-center italic">
    Authority worth trusting must be replayable at the moment it mattered.
  </p>
</div>

<script>
const btn = document.getElementById('ar-replay-btn') as HTMLButtonElement;
const area = document.getElementById('ar-reconstruction')!;

interface ReplayStep {
  label: string;
  status: 'valid' | 'expired' | 'warning';
  detail: string;
  delay: number; // ms from start
}

const steps: ReplayStep[] = [
  { label: 'Board signatory authority', status: 'valid', detail: 'Active since 1 May. No expiry set.', delay: 400 },
  { label: 'Programme Director delegation', status: 'valid', detail: 'Delegated 3 May. Valid until 22 June.', delay: 900 },
  { label: 'Regional Lead sub-delegation', status: 'expired', detail: 'Delegated 7 May. Expired 19 May.', delay: 1400 },
  { label: 'Temporary Approver authority', status: 'expired', detail: 'Inherited from Regional Lead. Upstream expired.', delay: 1900 },
  { label: 'Action authority at 09:23', status: 'expired', detail: 'Delegated approver expired at 09:19. No replacement grant active until 10:02.', delay: 2500 },
];

if (btn) {
  btn.addEventListener('click', () => {
    btn.style.opacity = '0.3';
    btn.style.pointerEvents = 'none';
    area.style.opacity = '1';
    area.innerHTML = '';

    for (const step of steps) {
      setTimeout(() => {
        const colors = {
          valid: { bg: 'rgba(74,222,128,0.06)', border: 'rgba(74,222,128,0.2)', text: 'rgba(74,222,128,0.8)', icon: '&#10003;' },
          expired: { bg: 'rgba(239,68,68,0.06)', border: 'rgba(239,68,68,0.2)', text: 'rgba(239,68,68,0.8)', icon: '&#10007;' },
          warning: { bg: 'rgba(245,158,11,0.06)', border: 'rgba(245,158,11,0.2)', text: 'rgba(245,158,11,0.8)', icon: '!' },
        };
        const c = colors[step.status];

        const el = document.createElement('div');
        el.style.cssText = `background:${c.bg}; border:1px solid ${c.border}; border-radius:8px; padding:12px 16px; opacity:0; transform:translateY(8px); transition: opacity 0.5s, transform 0.5s;`;
        el.innerHTML = `
          <div style="display:flex; align-items:center; gap:8px; margin-bottom:4px;">
            <span style="color:${c.text}; font-size:13px;">${c.icon}</span>
            <span style="color:${c.text}; font-weight:600; font-size:13px; font-family:'Syne',system-ui;">${step.label}</span>
          </div>
          <p style="color:rgba(232,232,240,0.4); font-size:12px; margin:0;">${step.detail}</p>
        `;
        area.appendChild(el);

        requestAnimationFrame(() => {
          el.style.opacity = '1';
          el.style.transform = 'translateY(0)';
        });

        // Final verdict
        if (step === steps[steps.length - 1]) {
          setTimeout(() => {
            const verdict = document.createElement('div');
            verdict.style.cssText = 'text-align:center; padding:16px 0; opacity:0; transition: opacity 0.8s;';
            verdict.innerHTML = `
              <p style="color:rgba(239,68,68,0.8); font-family:'Syne',system-ui; font-weight:700; font-size:15px;">Authority invalid at action time</p>
            `;
            area.appendChild(verdict);
            requestAnimationFrame(() => { verdict.style.opacity = '1'; });
          }, 600);
        }
      }, step.delay);
    }
  });
}
</script>
