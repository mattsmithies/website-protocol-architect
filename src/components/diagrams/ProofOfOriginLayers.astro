---
// Visual: Proof of origin layers
// Exploded diagram of a single state transition showing its proof layers
// Same interaction pattern as ContainerAnatomy.astro
---

<div class="reveal my-12 md:my-16">
  <div class="rounded-2xl border border-border overflow-hidden" style="background: rgba(11,11,17,0.6);">
    <div class="p-6 md:p-8">

      <p class="font-display font-bold text-text-primary text-base mb-1 max-w-2xl mx-auto">Transition: Awaiting review &rarr; Approved</p>
      <p class="text-text-tertiary text-[10px] uppercase tracking-wider font-semibold mb-5 max-w-2xl mx-auto">Select a layer to see what breaks without it</p>

      <div class="max-w-2xl mx-auto">
        <div id="pol-layers" class="space-y-0"></div>
      </div>

      <div id="pol-detail" class="mt-6 p-4 rounded-lg border border-border transition-all duration-300 max-w-2xl mx-auto" style="background: rgba(11,11,17,0.8);">
        <div class="flex items-start gap-3">
          <span id="pol-detail-icon" class="text-text-tertiary text-sm mt-0.5">&#8599;</span>
          <div>
            <p id="pol-detail-label" class="text-sm text-text-tertiary font-display font-semibold mb-1">Eight proof layers. Each one load-bearing.</p>
            <p id="pol-detail-text" class="text-sm text-text-tertiary leading-relaxed">Hover or tap any layer above to see what breaks when that proof element is missing.</p>
          </div>
        </div>
      </div>

    </div>
  </div>
  <p class="text-text-tertiary text-xs mt-3 text-center italic">
    Replayable history needs more than events. It needs preserved proof of who caused each meaningful change.
  </p>
</div>

<script>
interface ProofLayer {
  label: string;
  description: string;
  breakage: string;
  color: string;
  colorDim: string;
}

const layers: ProofLayer[] = [
  {
    label: 'Actor identity',
    description: 'Who caused this transition',
    breakage: 'Origin is ambiguous. The transition cannot be attributed.',
    color: 'rgba(167,139,250,0.8)',
    colorDim: 'rgba(167,139,250,0.15)',
  },
  {
    label: 'Key identifier',
    description: 'Which cryptographic key was used',
    breakage: 'The signature cannot be matched to a specific actor or device.',
    color: 'rgba(167,139,250,0.8)',
    colorDim: 'rgba(167,139,250,0.15)',
  },
  {
    label: 'Algorithm',
    description: 'How the signature should be verified',
    breakage: 'Later verification becomes brittle. Migration may break replay.',
    color: 'rgba(56,189,248,0.8)',
    colorDim: 'rgba(56,189,248,0.15)',
  },
  {
    label: 'Verification challenge',
    description: 'What nonce or context bound the proof',
    breakage: 'Replay attacks become possible. Proof is not bound to context.',
    color: 'rgba(56,189,248,0.8)',
    colorDim: 'rgba(56,189,248,0.15)',
  },
  {
    label: 'Content hash',
    description: 'What exactly was signed',
    breakage: 'The signed object is unstable. The signature may not match what was actually approved.',
    color: 'rgba(74,222,128,0.8)',
    colorDim: 'rgba(74,222,128,0.15)',
  },
  {
    label: 'Signature',
    description: 'The cryptographic proof itself',
    breakage: 'No cryptographic proof exists. The record is an assertion, not evidence.',
    color: 'rgba(74,222,128,0.8)',
    colorDim: 'rgba(74,222,128,0.15)',
  },
  {
    label: 'Timestamp',
    description: 'When the transition occurred',
    breakage: 'Ordering weakens. Temporal validity cannot be checked.',
    color: 'rgba(245,158,11,0.8)',
    colorDim: 'rgba(245,158,11,0.15)',
  },
  {
    label: 'Public anchor',
    description: 'External ordering or attestation reference',
    breakage: 'External attestation is absent. Trust depends entirely on the issuing system.',
    color: 'rgba(245,158,11,0.8)',
    colorDim: 'rgba(245,158,11,0.15)',
  },
];

const container = document.getElementById('pol-layers')!;
const detail = document.getElementById('pol-detail')!;
const detailIcon = document.getElementById('pol-detail-icon')!;
const detailLabel = document.getElementById('pol-detail-label')!;
const detailText = document.getElementById('pol-detail-text')!;

let activeLayer: HTMLElement | null = null;
let activeIndex = -1;

for (let i = 0; i < layers.length; i++) {
  const layer = layers[i];
  const row = document.createElement('div');
  row.className = 'group cursor-pointer transition-all duration-300';
  row.setAttribute('tabindex', '0');
  row.setAttribute('role', 'button');
  row.setAttribute('aria-label', `${layer.label} \u2014 select to see what breaks without it`);

  const isFirst = i === 0;
  const isLast = i === layers.length - 1;
  const borderRadius = isFirst ? 'border-radius: 8px 8px 0 0;' : isLast ? 'border-radius: 0 0 8px 8px;' : '';

  row.innerHTML = `
    <div class="flex items-center gap-4 px-5 py-4 border border-border transition-all duration-300" style="${borderRadius} border-bottom: ${isLast ? '1px' : '0'} solid rgba(255,255,255,0.06); background: ${layer.colorDim};">
      <span class="w-3 h-3 rounded-full flex-shrink-0 transition-all duration-300" style="background: ${layer.color}; opacity: 0.5;"></span>
      <div class="flex-1 min-w-0">
        <span class="text-sm font-display font-semibold text-text-primary transition-colors duration-300">${layer.label}</span>
        <span class="text-xs text-text-tertiary ml-2 hidden sm:inline">${layer.description}</span>
      </div>
      <span class="text-[10px] text-text-tertiary uppercase tracking-wider font-semibold opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex-shrink-0">Remove?</span>
    </div>
  `;

  function showDetail() {
    // Reset previous active layer
    if (activeLayer && activeLayer !== row) {
      const prevInner = activeLayer.querySelector('div') as HTMLElement;
      if (prevInner) {
        const prevIdx = activeIndex;
        prevInner.style.background = layers[prevIdx].colorDim;
        prevInner.style.borderColor = '';
      }
    }

    detail.style.opacity = '1';
    detail.style.borderColor = layer.color.replace('0.8', '0.3');
    detailIcon.textContent = '\u2717';
    detailIcon.style.color = 'rgba(239,68,68,0.8)';
    detailLabel.textContent = `Without: ${layer.label}`;
    detailLabel.style.color = layer.color;
    detailText.textContent = layer.breakage;
    detailText.style.color = 'rgba(232,232,240,0.6)';
    activeLayer = row;
    activeIndex = i;

    // Dim the layer visually (show as removed)
    const inner = row.querySelector('div') as HTMLElement;
    if (inner) {
      inner.style.background = 'rgba(239,68,68,0.06)';
      inner.style.borderColor = 'rgba(239,68,68,0.2)';
    }
  }

  function hideDetail() {
    if (activeLayer === row) {
      detail.style.opacity = '1';
      detail.style.borderColor = 'rgba(255,255,255,0.06)';
      detailIcon.textContent = '\u2197';
      detailIcon.style.color = '';
      detailLabel.textContent = 'Eight proof layers. Each one load-bearing.';
      detailLabel.style.color = '';
      detailText.textContent = 'Hover or tap any layer above to see what breaks when that proof element is missing.';
      detailText.style.color = '';
      activeLayer = null;
      activeIndex = -1;
      const inner = row.querySelector('div') as HTMLElement;
      if (inner) {
        inner.style.background = layer.colorDim;
        inner.style.borderColor = '';
      }
    }
  }

  row.addEventListener('mouseenter', showDetail);
  row.addEventListener('mouseleave', hideDetail);
  row.addEventListener('focus', showDetail);
  row.addEventListener('blur', hideDetail);

  row.addEventListener('click', (e) => {
    e.stopPropagation();
    if (activeLayer === row) {
      hideDetail();
    } else {
      showDetail();
    }
  });

  container.appendChild(row);
}

document.addEventListener('click', () => {
  if (activeLayer) {
    const prevIdx = activeIndex;
    const inner = activeLayer.querySelector('div') as HTMLElement;
    if (inner) {
      inner.style.background = layers[prevIdx].colorDim;
      inner.style.borderColor = '';
    }
    detail.style.opacity = '1';
    detail.style.borderColor = 'rgba(255,255,255,0.06)';
    detailIcon.textContent = '\u2197';
    detailIcon.style.color = '';
    detailLabel.textContent = 'Eight proof layers. Each one load-bearing.';
    detailLabel.style.color = '';
    detailText.textContent = 'Hover or tap any layer above to see what breaks when that proof element is missing.';
    detailText.style.color = '';
    activeLayer = null;
    activeIndex = -1;
  }
});
</script>
