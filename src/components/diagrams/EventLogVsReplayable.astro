---
// Visual 5: Event log versus replayable process
// Split panel — flat log on left, rich replayable record on right
---

<div class="reveal my-12 md:my-16">
  <div class="rounded-2xl border border-border overflow-hidden" style="background: rgba(11,11,17,0.6);">
    <div class="p-6 md:p-8">

      <!-- Time scrubber -->
      <div class="mb-6">
        <label for="elr-scrubber" class="sr-only">Scrub through event timeline</label>
        <input
          id="elr-scrubber"
          type="range" min="0" max="5" value="0" step="1"
          aria-label="Event timeline — scrub to compare flat log with replayable process"
          aria-valuemin="0"
          aria-valuemax="5"
          aria-valuenow="0"
          class="w-full accent-signal h-1 bg-border rounded-full appearance-none cursor-pointer"
        />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">

        <!-- Left panel: Event log -->
        <div>
          <p class="text-text-tertiary text-xs font-semibold tracking-[0.2em] uppercase mb-4">Event Log</p>
          <div id="elr-log" class="space-y-0 font-mono text-sm" aria-live="polite"></div>
        </div>

        <!-- Right panel: Replayable process -->
        <div>
          <p class="text-text-tertiary text-xs font-semibold tracking-[0.2em] uppercase mb-4">Replayable Process</p>
          <div id="elr-replay" class="space-y-0" aria-live="polite"></div>
        </div>

      </div>

      <!-- Comparison metrics -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 mt-6 border-t border-border pt-4">
        <div id="elr-metrics-left">
          <div class="grid grid-cols-2 gap-x-4 gap-y-1 text-xs font-mono">
            <span class="text-text-tertiary">Actions recorded</span><span style="color: rgba(232,232,240,0.55);">6</span>
            <span class="text-text-tertiary">Authority context</span><span style="color: rgba(239,68,68,0.7);">none</span>
            <span class="text-text-tertiary">Evidence binding</span><span style="color: rgba(239,68,68,0.7);">none</span>
            <span class="text-text-tertiary">Replayable</span><span style="color: rgba(239,68,68,0.7);">no</span>
          </div>
        </div>
        <div id="elr-metrics-right">
          <div class="grid grid-cols-2 gap-x-4 gap-y-1 text-xs font-mono">
            <span class="text-text-tertiary">Actions recorded</span><span style="color: rgba(232,232,240,0.55);">6</span>
            <span class="text-text-tertiary">Authority context</span><span style="color: rgba(74,222,128,0.7);">preserved</span>
            <span class="text-text-tertiary">Evidence binding</span><span style="color: rgba(74,222,128,0.7);">attached</span>
            <span class="text-text-tertiary">Replayable</span><span style="color: rgba(74,222,128,0.7);">yes</span>
          </div>
        </div>
      </div>

    </div>
  </div>
  <p class="text-text-tertiary text-xs mt-3 text-center italic">
    A list of actions is not the same thing as a trustworthy record of the workflow.
  </p>
</div>

<script>
interface LogEntry {
  time: string;
  label: string;
}

interface ReplayEntry {
  time: string;
  label: string;
  detail: string;
  color: 'green' | 'amber' | 'blue';
}

const logEntries: LogEntry[] = [
  { time: '09:02', label: 'Submitted' },
  { time: '09:11', label: 'Reviewed' },
  { time: '09:17', label: 'Evidence added' },
  { time: '09:23', label: 'Approved' },
  { time: '09:31', label: 'Countersigned' },
  { time: '09:45', label: 'Completed' },
];

const replayEntries: ReplayEntry[] = [
  { time: '09:02', label: 'Submitted by Actor A', detail: 'Under valid authority', color: 'green' },
  { time: '09:11', label: 'Returned for correction', detail: 'Evidence incomplete', color: 'amber' },
  { time: '09:17', label: 'Evidence resubmitted by Actor A', detail: 'Supporting documents attached', color: 'green' },
  { time: '09:23', label: 'Delegated to Actor B', detail: 'Original reviewer unavailable', color: 'blue' },
  { time: '09:31', label: 'Partial approval', detail: 'Under temporary authority', color: 'amber' },
  { time: '09:45', label: 'Final approval and completion', detail: 'Full authority chain valid', color: 'green' },
];

const colorMap = {
  green: { border: 'rgba(74,222,128,0.5)', bg: 'rgba(74,222,128,0.06)', text: 'rgba(74,222,128,0.8)' },
  amber: { border: 'rgba(245,158,11,0.5)', bg: 'rgba(245,158,11,0.06)', text: 'rgba(245,158,11,0.8)' },
  blue: { border: 'rgba(56,189,248,0.5)', bg: 'rgba(56,189,248,0.06)', text: 'rgba(56,189,248,0.8)' },
};

const scrubber = document.getElementById('elr-scrubber') as HTMLInputElement;
const logEl = document.getElementById('elr-log')!;
const replayEl = document.getElementById('elr-replay')!;

function renderStep(step: number) {
  // Left panel — flat log
  logEl.innerHTML = logEntries.map((entry, i) => {
    const isCurrent = i === step;
    const isPast = i < step;
    const isFuture = i > step;
    const opacity = isCurrent ? 1 : isPast ? 0.4 : 0.15;
    const bgColor = isCurrent ? 'rgba(167,139,250,0.06)' : 'transparent';
    const dotColor = isCurrent ? 'rgba(167,139,250,0.8)' : isPast ? 'rgba(167,139,250,0.3)' : 'rgba(167,139,250,0.1)';

    return `
      <div class="flex items-center gap-3 py-3 ${i < logEntries.length - 1 ? 'border-b border-border' : ''}" style="opacity: ${opacity}; background: ${bgColor}; padding-left: 8px; padding-right: 8px; transition: opacity 0.3s, background 0.3s;">
        <span class="w-2 h-2 rounded-full flex-shrink-0" style="background: ${dotColor}; transition: background 0.3s;"></span>
        <span class="text-text-tertiary font-mono" style="min-width: 42px;">${entry.time}</span>
        <span class="text-text-secondary">${entry.label}</span>
      </div>
    `;
  }).join('');

  // Right panel — replayable process
  replayEl.innerHTML = replayEntries.map((entry, i) => {
    const isCurrent = i === step;
    const isPast = i < step;
    const isFuture = i > step;
    const c = colorMap[entry.color];
    const opacity = isFuture ? 0 : isCurrent ? 1 : 0.5;
    const transform = isFuture ? 'translateY(8px)' : 'translateY(0)';
    const borderLeft = isFuture ? 'rgba(255,255,255,0.06)' : isCurrent ? c.border : c.border.replace('0.5', '0.2');

    return `
      <div class="py-3 pl-4 ${i < replayEntries.length - 1 ? 'border-b border-border' : ''}" style="opacity: ${opacity}; transform: ${transform}; border-left: 3px solid ${borderLeft}; background: ${isCurrent ? c.bg : 'transparent'}; transition: opacity 0.4s, transform 0.4s, background 0.3s, border-color 0.3s;">
        <div class="flex items-center gap-2 mb-1">
          <span class="font-mono text-xs text-text-tertiary" style="min-width: 42px;">${entry.time}</span>
          <span class="text-sm font-display font-semibold" style="color: ${isCurrent ? c.text : 'rgba(232,232,240,0.55)'}; transition: color 0.3s;">${entry.label}</span>
        </div>
        <p class="text-xs ml-[50px]" style="color: ${isCurrent ? c.text.replace('0.8', '0.6') : 'rgba(232,232,240,0.25)'}; transition: color 0.3s;">${entry.detail}</p>
      </div>
    `;
  }).join('');
}

if (scrubber) {
  scrubber.addEventListener('input', () => {
    const val = parseInt(scrubber.value);
    scrubber.setAttribute('aria-valuenow', String(val));
    renderStep(val);
  });
  renderStep(0);
}
</script>
