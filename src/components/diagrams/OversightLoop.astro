---
// Figure: Oversight loop
// Clean five-step horizontal loop. Use → Complaint → Review → Appeal
// → Audit and change → back into Use.
---

<div class="reveal my-12 md:my-16">
  <div class="rounded-2xl border border-border overflow-hidden" style="background: rgba(11,11,17,0.6);">
    <div class="p-6 md:p-8">

      <div class="mb-6">
        <p class="text-text-tertiary text-xs font-semibold tracking-[0.2em] uppercase mb-1">Governance surface</p>
        <h3 class="text-text-primary font-display font-bold text-lg tracking-tight">Oversight loop</h3>
      </div>

      <div class="w-full overflow-x-auto">
        <svg viewBox="0 0 900 200" class="w-full min-w-[720px]" role="img" aria-label="Five-step loop: use, complaint, review, appeal, audit and change, with an arrow returning to use.">
          <defs>
            <marker id="ol-arrow" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="8" markerHeight="8" orient="auto-start-reverse">
              <path d="M0,0 L10,5 L0,10 z" fill="rgba(167,139,250,0.75)"/>
            </marker>
          </defs>

          <!-- Steps -->
          <g>
            <rect x="30" y="60" width="140" height="60" rx="10" fill="rgba(56,189,248,0.08)" stroke="rgba(56,189,248,0.55)" stroke-width="1.3"/>
            <text x="100" y="85" text-anchor="middle" fill="rgba(232,232,240,0.9)" font-family="'Syne', system-ui" font-size="12" font-weight="600">01 · Use</text>
            <text x="100" y="102" text-anchor="middle" fill="rgba(232,232,240,0.55)" font-family="'Inter', system-ui" font-size="10">checks · services</text>
          </g>
          <line x1="170" y1="90" x2="200" y2="90" stroke="rgba(167,139,250,0.7)" stroke-width="1.5" marker-end="url(#ol-arrow)"/>

          <g>
            <rect x="200" y="60" width="140" height="60" rx="10" fill="rgba(245,158,11,0.08)" stroke="rgba(245,158,11,0.55)" stroke-width="1.3"/>
            <text x="270" y="85" text-anchor="middle" fill="rgba(232,232,240,0.9)" font-family="'Syne', system-ui" font-size="12" font-weight="600">02 · Complaint</text>
            <text x="270" y="102" text-anchor="middle" fill="rgba(232,232,240,0.55)" font-family="'Inter', system-ui" font-size="10">raised by holder or third party</text>
          </g>
          <line x1="340" y1="90" x2="370" y2="90" stroke="rgba(167,139,250,0.7)" stroke-width="1.5" marker-end="url(#ol-arrow)"/>

          <g>
            <rect x="370" y="60" width="140" height="60" rx="10" fill="rgba(245,158,11,0.08)" stroke="rgba(245,158,11,0.55)" stroke-width="1.3"/>
            <text x="440" y="85" text-anchor="middle" fill="rgba(232,232,240,0.9)" font-family="'Syne', system-ui" font-size="12" font-weight="600">03 · Review</text>
            <text x="440" y="102" text-anchor="middle" fill="rgba(232,232,240,0.55)" font-family="'Inter', system-ui" font-size="10">first-layer redress</text>
          </g>
          <line x1="510" y1="90" x2="540" y2="90" stroke="rgba(167,139,250,0.7)" stroke-width="1.5" marker-end="url(#ol-arrow)"/>

          <g>
            <rect x="540" y="60" width="140" height="60" rx="10" fill="rgba(239,68,68,0.06)" stroke="rgba(239,68,68,0.5)" stroke-width="1.3"/>
            <text x="610" y="85" text-anchor="middle" fill="rgba(232,232,240,0.9)" font-family="'Syne', system-ui" font-size="12" font-weight="600">04 · Appeal</text>
            <text x="610" y="102" text-anchor="middle" fill="rgba(232,232,240,0.55)" font-family="'Inter', system-ui" font-size="10">formal challenge</text>
          </g>
          <line x1="680" y1="90" x2="710" y2="90" stroke="rgba(167,139,250,0.7)" stroke-width="1.5" marker-end="url(#ol-arrow)"/>

          <g>
            <rect x="710" y="60" width="140" height="60" rx="10" fill="rgba(74,222,128,0.08)" stroke="rgba(74,222,128,0.55)" stroke-width="1.3"/>
            <text x="780" y="85" text-anchor="middle" fill="rgba(232,232,240,0.9)" font-family="'Syne', system-ui" font-size="12" font-weight="600">05 · Audit · change</text>
            <text x="780" y="102" text-anchor="middle" fill="rgba(232,232,240,0.55)" font-family="'Inter', system-ui" font-size="10">scrutiny · reporting · redesign</text>
          </g>

          <!-- Return arrow back to Use -->
          <path d="M 780 120 Q 780 165 440 165 Q 100 165 100 120" fill="none" stroke="rgba(74,222,128,0.55)" stroke-width="1.3" stroke-dasharray="5 4" marker-end="url(#ol-arrow)"/>
          <text x="440" y="188" text-anchor="middle" fill="rgba(74,222,128,0.8)" font-family="'JetBrains Mono', monospace" font-size="10">change feeds back into use</text>
        </svg>
      </div>

    </div>
  </div>
  <p class="text-text-tertiary text-xs mt-3 text-center italic">
    Oversight is an operating loop, not a promise above the system.
  </p>
</div>
