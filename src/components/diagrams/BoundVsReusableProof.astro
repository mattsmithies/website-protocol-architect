---
// Visual: Bound vs Reusable Proof
// Canvas-based dual flow — without and with context binding
---

<div class="reveal my-12 md:my-16">
  <div class="rounded-2xl border border-border overflow-hidden" style="background: rgba(11,11,17,0.6);">
    <div class="p-6 md:p-8">

      <canvas
        id="bvr-canvas"
        class="w-full"
        style="height: 380px;"
        role="img"
        aria-label="Two horizontal flows comparing proof reuse. Top flow shows a signed proof being reattached from its original action to a different action without protection. Bottom flow shows a nonce-bound proof that cannot be reused against a different action."
      ></canvas>

      <!-- Metrics -->
      <div class="grid grid-cols-2 gap-4 mt-4 border-t border-border pt-4">
        <div>
          <p class="text-[10px] text-text-tertiary uppercase tracking-wider mb-1">Context binding</p>
          <div class="space-y-1">
            <p class="text-xs font-display font-bold" style="color: rgba(239,68,68,0.8);">Without: None — reusable</p>
            <p class="text-xs font-display font-bold" style="color: rgba(74,222,128,0.8);">With: Nonce bound — single use</p>
          </div>
        </div>
        <div>
          <p class="text-[10px] text-text-tertiary uppercase tracking-wider mb-1">Replay protection</p>
          <div class="space-y-1">
            <p class="text-xs font-display font-bold" style="color: rgba(239,68,68,0.8);">Without: Vulnerable</p>
            <p class="text-xs font-display font-bold" style="color: rgba(74,222,128,0.8);">With: Protected</p>
          </div>
        </div>
      </div>

    </div>
  </div>
  <p class="text-text-tertiary text-xs mt-3 text-center italic">
    Without context binding, a valid proof from one action can be reused against another.
  </p>
</div>

<script>
const canvas = document.getElementById('bvr-canvas') as HTMLCanvasElement;

if (canvas) {
  const ctx = canvas.getContext('2d')!;

  const RED: [number, number, number] = [239, 68, 68];
  const GREEN: [number, number, number] = [74, 222, 128];
  const AMBER: [number, number, number] = [245, 158, 11];
  const DIM: [number, number, number] = [100, 100, 120];

  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let animId = 0;

  interface Particle {
    t: number;
    speed: number;
    path: 'top-left' | 'top-right' | 'bottom-left' | 'bottom-right';
  }

  const particles: Particle[] = [];

  // Top flow particles (both arrows active — reusable)
  for (let i = 0; i < 5; i++) {
    particles.push({ t: Math.random(), speed: 0.0004 + Math.random() * 0.0003, path: 'top-left' });
    particles.push({ t: Math.random(), speed: 0.0004 + Math.random() * 0.0003, path: 'top-right' });
  }
  // Bottom flow particles (only left arrow active — bound)
  for (let i = 0; i < 5; i++) {
    particles.push({ t: Math.random(), speed: 0.0004 + Math.random() * 0.0003, path: 'bottom-left' });
  }

  function resize() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function drawRoundedRect(x: number, y: number, w: number, h: number, r: number) {
    ctx.beginPath();
    ctx.roundRect(x, y, w, h, r);
  }

  function drawArrow(x1: number, y1: number, x2: number, y2: number, color: [number, number, number], alpha: number, lineWidth: number, dashed: boolean) {
    const [r, g, b] = color;
    ctx.beginPath();
    ctx.moveTo(x1, y1);
    ctx.lineTo(x2, y2);
    ctx.strokeStyle = `rgba(${r},${g},${b},${alpha})`;
    ctx.lineWidth = lineWidth;
    if (dashed) ctx.setLineDash([4, 4]);
    ctx.stroke();
    if (dashed) ctx.setLineDash([]);

    // Arrowhead
    const angle = Math.atan2(y2 - y1, x2 - x1);
    const headLen = 8;
    ctx.beginPath();
    ctx.moveTo(x2, y2);
    ctx.lineTo(x2 - headLen * Math.cos(angle - 0.4), y2 - headLen * Math.sin(angle - 0.4));
    ctx.lineTo(x2 - headLen * Math.cos(angle + 0.4), y2 - headLen * Math.sin(angle + 0.4));
    ctx.closePath();
    ctx.fillStyle = `rgba(${r},${g},${b},${alpha})`;
    ctx.fill();
  }

  function drawX(cx: number, cy: number, size: number, color: [number, number, number], alpha: number) {
    const [r, g, b] = color;
    ctx.strokeStyle = `rgba(${r},${g},${b},${alpha})`;
    ctx.lineWidth = 2.5;
    ctx.lineCap = 'round';
    ctx.beginPath();
    ctx.moveTo(cx - size, cy - size);
    ctx.lineTo(cx + size, cy + size);
    ctx.stroke();
    ctx.beginPath();
    ctx.moveTo(cx + size, cy - size);
    ctx.lineTo(cx - size, cy + size);
    ctx.stroke();
    ctx.lineCap = 'butt';
  }

  function drawCheck(cx: number, cy: number, size: number, color: [number, number, number], alpha: number) {
    const [r, g, b] = color;
    ctx.strokeStyle = `rgba(${r},${g},${b},${alpha})`;
    ctx.lineWidth = 2.5;
    ctx.lineCap = 'round';
    ctx.lineJoin = 'round';
    ctx.beginPath();
    ctx.moveTo(cx - size * 0.6, cy);
    ctx.lineTo(cx - size * 0.1, cy + size * 0.5);
    ctx.lineTo(cx + size * 0.7, cy - size * 0.4);
    ctx.stroke();
    ctx.lineCap = 'butt';
    ctx.lineJoin = 'miter';
  }

  function render(now: number) {
    const w = canvas.clientWidth;
    const h = canvas.clientHeight;
    const isNarrow = w < 500;
    ctx.clearRect(0, 0, w, h);

    const margin = isNarrow ? 16 : 40;
    const nodeW = isNarrow ? 80 : 110;
    const nodeH = isNarrow ? 40 : 48;
    const proofW = isNarrow ? 90 : 130;
    const proofH = isNarrow ? 44 : 52;

    const flowW = w - margin * 2;
    const cx = w / 2;

    // Top flow Y centre, bottom flow Y centre
    const topY = isNarrow ? h * 0.22 : h * 0.24;
    const bottomY = isNarrow ? h * 0.72 : h * 0.74;
    const dividerY = h * 0.48;

    // Node X positions: left, centre, right
    const leftX = margin + nodeW / 2;
    const rightX = w - margin - nodeW / 2;

    // ── Dividing line ──
    ctx.beginPath();
    ctx.moveTo(margin, dividerY);
    ctx.lineTo(w - margin, dividerY);
    ctx.strokeStyle = 'rgba(255,255,255,0.06)';
    ctx.lineWidth = 1;
    ctx.stroke();

    // Section labels
    ctx.font = `600 ${isNarrow ? 9 : 11}px "Syne", system-ui`;
    ctx.textAlign = 'left';
    ctx.fillStyle = `rgba(${RED[0]},${RED[1]},${RED[2]},0.5)`;
    ctx.fillText('Without context binding', margin, isNarrow ? 14 : 18);
    ctx.fillStyle = `rgba(${GREEN[0]},${GREEN[1]},${GREEN[2]},0.5)`;
    ctx.fillText('With context binding', margin, dividerY + (isNarrow ? 16 : 20));

    // ══════════════════════════════════════════════
    // TOP FLOW (red — reusable, no binding)
    // ══════════════════════════════════════════════

    // Arrows: Original -> Proof (solid)
    drawArrow(leftX + nodeW / 2 + 4, topY, cx - proofW / 2 - 4, topY, DIM, 0.3, 1.5, false);
    // Arrows: Proof -> Different action (solid red — reattached)
    drawArrow(cx + proofW / 2 + 4, topY, rightX - nodeW / 2 - 4, topY, RED, 0.4, 1.5, false);

    // Particles on top paths
    if (!prefersReducedMotion) {
      for (const p of particles) {
        if (p.path === 'top-left') {
          p.t += p.speed;
          if (p.t > 1) p.t -= 1;
          const px = (leftX + nodeW / 2 + 4) + p.t * (cx - proofW / 2 - 4 - leftX - nodeW / 2 - 4);
          ctx.beginPath();
          ctx.arc(px, topY, 2, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${DIM[0]},${DIM[1]},${DIM[2]},${0.2 + 0.3 * Math.sin(p.t * Math.PI)})`;
          ctx.fill();
        } else if (p.path === 'top-right') {
          p.t += p.speed;
          if (p.t > 1) p.t -= 1;
          const px = (cx + proofW / 2 + 4) + p.t * (rightX - nodeW / 2 - 4 - cx - proofW / 2 - 4);
          ctx.beginPath();
          ctx.arc(px, topY, 2, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${RED[0]},${RED[1]},${RED[2]},${0.2 + 0.3 * Math.sin(p.t * Math.PI)})`;
          ctx.fill();
        }
      }
    }

    // "Proof reattached" label on right arrow
    ctx.font = `500 ${isNarrow ? 7 : 9}px "Syne", system-ui`;
    ctx.textAlign = 'center';
    ctx.fillStyle = `rgba(${RED[0]},${RED[1]},${RED[2]},0.55)`;
    const topRightMidX = (cx + proofW / 2 + rightX - nodeW / 2) / 2;
    ctx.fillText('Proof reattached', topRightMidX, topY - (isNarrow ? 8 : 10));

    // Original action node (left)
    drawRoundedRect(leftX - nodeW / 2, topY - nodeH / 2, nodeW, nodeH, 6);
    ctx.fillStyle = 'rgba(100,100,120,0.06)';
    ctx.fill();
    ctx.strokeStyle = 'rgba(100,100,120,0.25)';
    ctx.lineWidth = 1;
    ctx.stroke();
    ctx.font = `600 ${isNarrow ? 8 : 10}px "Syne", system-ui`;
    ctx.fillStyle = 'rgba(232,232,240,0.6)';
    ctx.textAlign = 'center';
    ctx.fillText('Original action', leftX, topY + 3);

    // Signed proof node (centre)
    drawRoundedRect(cx - proofW / 2, topY - proofH / 2, proofW, proofH, 6);
    ctx.fillStyle = `rgba(${RED[0]},${RED[1]},${RED[2]},0.05)`;
    ctx.fill();
    ctx.strokeStyle = `rgba(${RED[0]},${RED[1]},${RED[2]},0.3)`;
    ctx.lineWidth = 1.5;
    ctx.stroke();
    ctx.font = `600 ${isNarrow ? 8 : 10}px "Syne", system-ui`;
    ctx.fillStyle = `rgba(${RED[0]},${RED[1]},${RED[2]},0.7)`;
    ctx.textAlign = 'center';
    ctx.fillText('Signed proof', cx, topY + 3);

    // Different action node (right) with amber check turning to concern
    drawRoundedRect(rightX - nodeW / 2, topY - nodeH / 2, nodeW, nodeH, 6);
    ctx.fillStyle = `rgba(${AMBER[0]},${AMBER[1]},${AMBER[2]},0.05)`;
    ctx.fill();
    ctx.strokeStyle = `rgba(${AMBER[0]},${AMBER[1]},${AMBER[2]},0.25)`;
    ctx.lineWidth = 1;
    ctx.stroke();
    ctx.font = `600 ${isNarrow ? 8 : 10}px "Syne", system-ui`;
    ctx.fillStyle = `rgba(${AMBER[0]},${AMBER[1]},${AMBER[2]},0.7)`;
    ctx.textAlign = 'center';
    ctx.fillText('Different action', rightX, topY + 3);

    // Amber check on right node (accepts it wrongly)
    const checkX = rightX + nodeW / 2 + (isNarrow ? 10 : 14);
    drawCheck(checkX, topY, isNarrow ? 6 : 8, AMBER, 0.7);

    // Top status text
    ctx.font = `500 ${isNarrow ? 8 : 10}px "Syne", system-ui`;
    ctx.fillStyle = `rgba(${RED[0]},${RED[1]},${RED[2]},0.6)`;
    ctx.textAlign = 'center';
    const topStatusY = topY + proofH / 2 + (isNarrow ? 16 : 22);
    const topStatus = 'Same bytes. Different context. Fact claim now ambiguous.';
    // Word-wrap
    const maxStatusW = w - margin * 2 - 20;
    const topWords = topStatus.split(' ');
    const topLines: string[] = [];
    let tLine = '';
    for (const word of topWords) {
      const test = tLine ? tLine + ' ' + word : word;
      if (ctx.measureText(test).width > maxStatusW && tLine) {
        topLines.push(tLine);
        tLine = word;
      } else {
        tLine = test;
      }
    }
    if (tLine) topLines.push(tLine);
    for (let l = 0; l < topLines.length; l++) {
      ctx.fillText(topLines[l], cx, topStatusY + l * (isNarrow ? 12 : 14));
    }

    // ══════════════════════════════════════════════
    // BOTTOM FLOW (green — bound, nonce-protected)
    // ══════════════════════════════════════════════

    // Arrows: Original -> Proof (solid green)
    drawArrow(leftX + nodeW / 2 + 4, bottomY, cx - proofW / 2 - 4, bottomY, GREEN, 0.4, 1.5, false);
    // Arrows: Proof -> Different action (dashed red with X)
    drawArrow(cx + proofW / 2 + 4, bottomY, rightX - nodeW / 2 - 4, bottomY, RED, 0.2, 1, true);

    // Particles on bottom left path only
    if (!prefersReducedMotion) {
      for (const p of particles) {
        if (p.path === 'bottom-left') {
          p.t += p.speed;
          if (p.t > 1) p.t -= 1;
          const px = (leftX + nodeW / 2 + 4) + p.t * (cx - proofW / 2 - 4 - leftX - nodeW / 2 - 4);
          ctx.beginPath();
          ctx.arc(px, bottomY, 2, 0, Math.PI * 2);
          ctx.fillStyle = `rgba(${GREEN[0]},${GREEN[1]},${GREEN[2]},${0.2 + 0.4 * Math.sin(p.t * Math.PI)})`;
          ctx.fill();
        }
      }
    }

    // X on dashed arrow midpoint
    const bottomRightMidX = (cx + proofW / 2 + rightX - nodeW / 2) / 2;
    drawX(bottomRightMidX, bottomY, isNarrow ? 5 : 7, RED, 0.6);

    // Original action node (left)
    drawRoundedRect(leftX - nodeW / 2, bottomY - nodeH / 2, nodeW, nodeH, 6);
    ctx.fillStyle = 'rgba(100,100,120,0.06)';
    ctx.fill();
    ctx.strokeStyle = 'rgba(100,100,120,0.25)';
    ctx.lineWidth = 1;
    ctx.stroke();
    ctx.font = `600 ${isNarrow ? 8 : 10}px "Syne", system-ui`;
    ctx.fillStyle = 'rgba(232,232,240,0.6)';
    ctx.textAlign = 'center';
    ctx.fillText('Original action', leftX, bottomY + 3);

    // Bound proof node (centre) — green with internal labels
    drawRoundedRect(cx - proofW / 2, bottomY - proofH / 2, proofW, proofH, 6);
    ctx.fillStyle = `rgba(${GREEN[0]},${GREEN[1]},${GREEN[2]},0.05)`;
    ctx.fill();
    ctx.strokeStyle = `rgba(${GREEN[0]},${GREEN[1]},${GREEN[2]},0.3)`;
    ctx.lineWidth = 1.5;
    ctx.stroke();

    // Glow
    ctx.shadowColor = `rgba(${GREEN[0]},${GREEN[1]},${GREEN[2]},0.12)`;
    ctx.shadowBlur = 10;
    ctx.stroke();
    ctx.shadowBlur = 0;

    ctx.font = `600 ${isNarrow ? 7 : 9}px "Syne", system-ui`;
    ctx.fillStyle = `rgba(${GREEN[0]},${GREEN[1]},${GREEN[2]},0.7)`;
    ctx.textAlign = 'center';
    ctx.fillText('Bound proof', cx, bottomY - (isNarrow ? 6 : 8));

    // Internal labels
    ctx.font = `400 ${isNarrow ? 6 : 7}px "JetBrains Mono", monospace`;
    ctx.fillStyle = `rgba(${GREEN[0]},${GREEN[1]},${GREEN[2]},0.45)`;
    ctx.fillText('content + nonce + signature', cx, bottomY + (isNarrow ? 6 : 8));

    // Nonce label below proof node
    ctx.font = `400 ${isNarrow ? 6 : 7}px "JetBrains Mono", monospace`;
    ctx.fillStyle = `rgba(${GREEN[0]},${GREEN[1]},${GREEN[2]},0.35)`;
    ctx.fillText('nonce: n-4821', cx, bottomY + proofH / 2 + (isNarrow ? 10 : 12));

    // Different action node (right) — rejected
    drawRoundedRect(rightX - nodeW / 2, bottomY - nodeH / 2, nodeW, nodeH, 6);
    ctx.fillStyle = 'rgba(239,68,68,0.03)';
    ctx.fill();
    ctx.strokeStyle = 'rgba(239,68,68,0.15)';
    ctx.lineWidth = 1;
    ctx.setLineDash([3, 3]);
    ctx.stroke();
    ctx.setLineDash([]);
    ctx.font = `600 ${isNarrow ? 8 : 10}px "Syne", system-ui`;
    ctx.fillStyle = 'rgba(239,68,68,0.45)';
    ctx.textAlign = 'center';
    ctx.fillText('Different action', rightX, bottomY + 3);

    // X on the right node (rejected)
    const rejectX = rightX + nodeW / 2 + (isNarrow ? 10 : 14);
    drawX(rejectX, bottomY, isNarrow ? 6 : 8, RED, 0.6);

    // Bottom status text
    ctx.font = `500 ${isNarrow ? 8 : 10}px "Syne", system-ui`;
    ctx.fillStyle = `rgba(${GREEN[0]},${GREEN[1]},${GREEN[2]},0.6)`;
    ctx.textAlign = 'center';
    const bottomStatusY = bottomY + proofH / 2 + (isNarrow ? 24 : 30);
    ctx.fillText('Proof bound to original action. Cannot be reused.', cx, bottomStatusY);

    if (!prefersReducedMotion) {
      animId = requestAnimationFrame(render);
    }
  }

  resize();
  window.addEventListener('resize', () => { resize(); if (prefersReducedMotion) render(0); });

  if (!prefersReducedMotion) {
    animId = requestAnimationFrame(render);
  } else {
    render(0);
  }
}
</script>
