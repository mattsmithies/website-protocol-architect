---
// Happy Path vs Real Path — toggle reveals how the real process diverges from the diagram
---

<div class="reveal my-12 md:my-16">
  <div class="rounded-2xl border border-border overflow-hidden" style="background: rgba(11,11,17,0.6);">
    <div class="p-6 md:p-8">

      <div class="flex items-center justify-center gap-3 sm:gap-4 mb-6" role="group" aria-label="Toggle between happy path and real process">
        <button id="hp-happy" class="px-3 sm:px-4 py-2 rounded-full text-xs font-display font-semibold transition-all duration-300 cursor-pointer" role="tab" aria-selected="true" style="background: rgba(74,222,128,0.12); color: rgba(74,222,128,0.9); border: 1px solid rgba(74,222,128,0.3);">
          Happy path
        </button>
        <button id="hp-real" class="px-3 sm:px-4 py-2 rounded-full text-xs font-display font-semibold transition-all duration-300 cursor-pointer" role="tab" aria-selected="false" style="background: transparent; color: rgba(232,232,240,0.3); border: 1px solid rgba(255,255,255,0.06);">
          Real process
        </button>
      </div>

      <canvas id="hp-canvas" class="w-full" style="height: 560px;" role="img" aria-label="Comparison of a clean happy path workflow against a real-world workflow with exceptions, branches, and returns"></canvas>

      <div class="grid grid-cols-3 gap-4 mt-4 border-t border-border pt-4 text-center" aria-live="polite">
        <div>
          <p class="text-[13px] text-text-tertiary uppercase tracking-wider">Steps</p>
          <p class="text-sm font-display font-bold" id="hp-steps">—</p>
        </div>
        <div>
          <p class="text-[13px] text-text-tertiary uppercase tracking-wider">Branches</p>
          <p class="text-sm font-display font-bold" id="hp-branches">—</p>
        </div>
        <div>
          <p class="text-[13px] text-text-tertiary uppercase tracking-wider">Exceptions</p>
          <p class="text-sm font-display font-bold" id="hp-exceptions">—</p>
        </div>
      </div>

    </div>
  </div>
  <p class="text-text-tertiary text-xs mt-3 text-center italic">
    The happy path is not the workflow. It is the least interesting version of the workflow.
  </p>
</div>

<script>
const canvas = document.getElementById('hp-canvas') as HTMLCanvasElement;
const btnHappy = document.getElementById('hp-happy') as HTMLButtonElement;
const btnReal = document.getElementById('hp-real') as HTMLButtonElement;

if (canvas && btnHappy && btnReal) {
  const ctx = canvas.getContext('2d')!;
  let mode: 'happy' | 'real' = 'happy';
  let animId = 0;

  const GREEN: [number, number, number] = [74, 222, 128];
  const RED: [number, number, number] = [239, 68, 68];
  const AMBER: [number, number, number] = [245, 158, 11];
  const BLUE: [number, number, number] = [56, 189, 248];
  const VIOLET: [number, number, number] = [167, 139, 250];

  function resize() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function measureNode(label: string, small: boolean): { halfW: number; halfH: number } {
    const isNarrow = canvas.clientWidth < 500;
    const fontSize = small ? (isNarrow ? 10 : 11) : (isNarrow ? 12 : 13);
    ctx.font = `600 ${fontSize}px "Syne", system-ui`;
    const lines = label.split('\n');
    const lineH = fontSize + 6;
    let maxW = 0;
    for (const line of lines) {
      const m = ctx.measureText(line);
      if (m.width > maxW) maxW = m.width;
    }
    const padX = isNarrow ? 14 : 20;
    const padY = isNarrow ? 8 : 10;
    return { halfW: maxW / 2 + padX, halfH: (lines.length * lineH) / 2 + padY };
  }

  function drawNode(x: number, y: number, label: string, color: [number, number, number], alpha: number, small?: boolean) {
    const [cr, cg, cb] = color;
    const isNarrow = canvas.clientWidth < 500;
    const fontSize = small ? (isNarrow ? 10 : 11) : (isNarrow ? 12 : 13);
    ctx.font = `600 ${fontSize}px "Syne", system-ui`;
    const lines = label.split('\n');
    const lineH = fontSize + 6;
    let maxW = 0;
    for (const line of lines) {
      const m = ctx.measureText(line);
      if (m.width > maxW) maxW = m.width;
    }
    const padX = isNarrow ? 14 : 20;
    const padY = isNarrow ? 8 : 10;
    const halfW = maxW / 2 + padX;
    const halfH = (lines.length * lineH) / 2 + padY;

    // Glow
    const glowR = Math.max(halfW, halfH) * 2;
    const grad = ctx.createRadialGradient(x, y, 0, x, y, glowR);
    grad.addColorStop(0, `rgba(${cr},${cg},${cb},${alpha * 0.06})`);
    grad.addColorStop(1, `rgba(${cr},${cg},${cb},0)`);
    ctx.fillStyle = grad;
    ctx.beginPath();
    ctx.arc(x, y, glowR, 0, Math.PI * 2);
    ctx.fill();

    // Rounded rect
    ctx.beginPath();
    ctx.roundRect(x - halfW, y - halfH, halfW * 2, halfH * 2, 8);
    ctx.fillStyle = `rgba(${cr},${cg},${cb},${alpha * 0.06})`;
    ctx.fill();
    ctx.strokeStyle = `rgba(${cr},${cg},${cb},${alpha * 0.45})`;
    ctx.lineWidth = 1.5;
    ctx.stroke();

    // Text
    ctx.fillStyle = `rgba(232,232,240,${alpha * 0.9})`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    lines.forEach((line, i) => {
      ctx.fillText(line, x, y + (i - (lines.length - 1) / 2) * lineH);
    });
    ctx.textBaseline = 'alphabetic';
  }

  function drawEdge(x1: number, y1: number, x2: number, y2: number, color: [number, number, number], alpha: number, dashed: boolean) {
    const [cr, cg, cb] = color;
    ctx.beginPath();
    ctx.moveTo(x1, y1);
    ctx.lineTo(x2, y2);
    ctx.strokeStyle = `rgba(${cr},${cg},${cb},${alpha})`;
    ctx.lineWidth = 1.2;
    if (dashed) ctx.setLineDash([4, 4]);
    ctx.stroke();
    ctx.setLineDash([]);
  }

  function render(now: number) {
    const w = canvas.clientWidth;
    const h = canvas.clientHeight;
    const t = now * 0.001;
    const isNarrow = w < 500;

    ctx.clearRect(0, 0, w, h);

    const cx = w / 2;

    if (mode === 'happy') {
      const steps = ['Submit', 'Approve', 'Complete'];
      const topY = 70;
      const spacing = (h - 140) / 2;

      // Measure all nodes first for edge connections
      const dims = steps.map(s => measureNode(s, false));

      // Draw edges first (behind nodes)
      for (let i = 0; i < 2; i++) {
        const y1 = topY + i * spacing + dims[i].halfH;
        const y2 = topY + (i + 1) * spacing - dims[i + 1].halfH;
        drawEdge(cx, y1, cx, y2, GREEN, 0.25, false);
        // Particle
        const pt = ((t * 0.15 + i * 0.4) % 1);
        const py = y1 + (y2 - y1) * pt;
        ctx.beginPath();
        ctx.arc(cx, py, 2.5, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(74,222,128,0.5)';
        ctx.fill();
      }

      // Draw nodes on top
      for (let i = 0; i < 3; i++) {
        drawNode(cx, topY + i * spacing, steps[i], GREEN, 0.9);
      }

      ctx.font = `400 ${isNarrow ? 11 : 12}px "Inter", system-ui`;
      ctx.fillStyle = 'rgba(74,222,128,0.4)';
      ctx.textAlign = 'center';
      ctx.fillText('Three steps. No exceptions. No branches.', cx, h - 18);

    } else {
      // Real process — full complexity
      const topY = 40;
      const spacing = isNarrow ? 56 : 60;
      const branchX = isNarrow ? w * 0.32 : w * 0.34;

      // Main spine
      const spineLabels = [
        'Submit',
        isNarrow ? 'Under review' : 'Under review',
        isNarrow ? 'Evidence resubmitted' : 'Evidence resubmitted',
        isNarrow ? 'Delegated review' : 'Delegated review',
        isNarrow ? 'Partial approval' : 'Partial approval',
        'Resume',
        'Approve',
        'Complete',
      ];
      const spineColors = [VIOLET, BLUE, AMBER, BLUE, AMBER, GREEN, GREEN, GREEN];
      const spineSmall = [false, false, true, true, true, true, false, false];

      const spineY = spineLabels.map((_, i) => topY + i * spacing);
      const spineDims = spineLabels.map((l, i) => measureNode(l, spineSmall[i]));

      // Spine edges (behind)
      for (let i = 0; i < spineLabels.length - 1; i++) {
        const y1 = spineY[i] + spineDims[i].halfH;
        const y2 = spineY[i + 1] - spineDims[i + 1].halfH;
        drawEdge(cx, y1, cx, y2, spineColors[i + 1], 0.2, false);
      }

      // Branch edges (behind)
      const evLabel = isNarrow ? 'Evidence missing' : 'Evidence missing';
      const evDims = measureNode(evLabel, true);
      const evX = cx - branchX;
      const evY = spineY[1];
      drawEdge(cx - spineDims[1].halfW, spineY[1], evX + evDims.halfW, evY, AMBER, 0.3, true);

      const authLabel = isNarrow ? 'Authority expired' : 'Authority expired';
      const authDims = measureNode(authLabel, true);
      const authX = cx + branchX;
      const authY = spineY[1];
      drawEdge(cx + spineDims[1].halfW, spineY[1], authX - authDims.halfW, authY, RED, 0.3, true);

      const pauseLabel = isNarrow ? 'Paused' : 'Paused — external';
      const pauseDims = measureNode(pauseLabel, true);
      const pauseX = cx + branchX;
      const pauseY = spineY[4];
      drawEdge(cx + spineDims[4].halfW, spineY[4], pauseX - pauseDims.halfW, pauseY, BLUE, 0.3, true);

      // Return arrow from review back to submit
      ctx.beginPath();
      const retX = cx - branchX * 0.55;
      ctx.moveTo(cx - spineDims[1].halfW, spineY[1] - 5);
      ctx.quadraticCurveTo(retX, (spineY[0] + spineY[1]) / 2, cx - spineDims[0].halfW, spineY[0] + 5);
      ctx.strokeStyle = 'rgba(239,68,68,0.25)';
      ctx.lineWidth = 1;
      ctx.setLineDash([4, 4]);
      ctx.stroke();
      ctx.setLineDash([]);

      ctx.font = `500 ${isNarrow ? 9 : 10}px "JetBrains Mono", monospace`;
      ctx.fillStyle = 'rgba(239,68,68,0.5)';
      ctx.textAlign = 'center';
      ctx.fillText('RETURN', retX - 4, (spineY[0] + spineY[1]) / 2 - 3);

      // Draw spine nodes (on top)
      for (let i = 0; i < spineLabels.length; i++) {
        drawNode(cx, spineY[i], spineLabels[i], spineColors[i], 0.85, spineSmall[i]);
      }

      // Draw branch nodes (on top)
      drawNode(evX, evY, evLabel, AMBER, 0.7, true);
      drawNode(authX, authY, authLabel, RED, 0.7, true);
      drawNode(pauseX, pauseY, pauseLabel, BLUE, 0.7, true);

      ctx.font = `400 ${isNarrow ? 11 : 12}px "Inter", system-ui`;
      ctx.fillStyle = 'rgba(239,68,68,0.4)';
      ctx.textAlign = 'center';
      ctx.fillText('Eight steps. Three branches. Two warnings. One return.', cx, h - 18);
    }

    animId = requestAnimationFrame(render);
  }

  function updateMetrics(m: 'happy' | 'real') {
    const s = document.getElementById('hp-steps')!;
    const b = document.getElementById('hp-branches')!;
    const e = document.getElementById('hp-exceptions')!;
    if (m === 'happy') {
      s.textContent = '3'; s.style.color = 'rgba(74,222,128,0.8)';
      b.textContent = '0'; b.style.color = 'rgba(74,222,128,0.8)';
      e.textContent = '0'; e.style.color = 'rgba(74,222,128,0.8)';
    } else {
      s.textContent = '8'; s.style.color = 'rgba(245,158,11,0.8)';
      b.textContent = '3'; b.style.color = 'rgba(239,68,68,0.8)';
      e.textContent = '2'; e.style.color = 'rgba(239,68,68,0.8)';
    }
  }

  function setMode(m: 'happy' | 'real') {
    mode = m;
    updateMetrics(m);
    btnHappy.setAttribute('aria-selected', String(m === 'happy'));
    btnReal.setAttribute('aria-selected', String(m === 'real'));
    if (m === 'happy') {
      btnHappy.style.background = 'rgba(74,222,128,0.12)';
      btnHappy.style.color = 'rgba(74,222,128,0.9)';
      btnHappy.style.borderColor = 'rgba(74,222,128,0.3)';
      btnReal.style.background = 'transparent';
      btnReal.style.color = 'rgba(232,232,240,0.3)';
      btnReal.style.borderColor = 'rgba(255,255,255,0.06)';
    } else {
      btnReal.style.background = 'rgba(239,68,68,0.12)';
      btnReal.style.color = 'rgba(239,68,68,0.9)';
      btnReal.style.borderColor = 'rgba(239,68,68,0.3)';
      btnHappy.style.background = 'transparent';
      btnHappy.style.color = 'rgba(232,232,240,0.3)';
      btnHappy.style.borderColor = 'rgba(255,255,255,0.06)';
    }
  }

  btnHappy.addEventListener('click', () => setMode('happy'));
  btnReal.addEventListener('click', () => setMode('real'));

  resize();
  updateMetrics('happy');
  window.addEventListener('resize', resize);
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    animId = requestAnimationFrame(render);
  } else { render(5000); }
}
</script>
