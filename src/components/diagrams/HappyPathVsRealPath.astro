---
// Happy Path vs Real Path — toggle reveals how the real process diverges from the diagram
---

<div class="reveal my-12 md:my-16">
  <div class="rounded-2xl border border-border overflow-hidden" style="background: rgba(11,11,17,0.6);">
    <div class="p-6 md:p-8">

      <div class="flex items-center justify-center gap-3 sm:gap-4 mb-6" role="group" aria-label="Toggle between happy path and real process">
        <button id="hp-happy" class="px-3 sm:px-4 py-2 rounded-full text-xs font-display font-semibold transition-all duration-300 cursor-pointer" role="tab" aria-selected="true" style="background: rgba(74,222,128,0.12); color: rgba(74,222,128,0.9); border: 1px solid rgba(74,222,128,0.3);">
          Happy path
        </button>
        <button id="hp-real" class="px-3 sm:px-4 py-2 rounded-full text-xs font-display font-semibold transition-all duration-300 cursor-pointer" role="tab" aria-selected="false" style="background: transparent; color: rgba(232,232,240,0.3); border: 1px solid rgba(255,255,255,0.06);">
          Real process
        </button>
      </div>

      <canvas id="hp-canvas" class="w-full" style="height: 380px;" role="img" aria-label="Comparison of a clean happy path workflow against a real-world workflow with exceptions, branches, and returns"></canvas>

      <div class="grid grid-cols-3 gap-4 mt-4 border-t border-border pt-4 text-center" aria-live="polite">
        <div>
          <p class="text-[10px] text-text-tertiary uppercase tracking-wider">Steps</p>
          <p class="text-sm font-display font-bold" id="hp-steps">—</p>
        </div>
        <div>
          <p class="text-[10px] text-text-tertiary uppercase tracking-wider">Branches</p>
          <p class="text-sm font-display font-bold" id="hp-branches">—</p>
        </div>
        <div>
          <p class="text-[10px] text-text-tertiary uppercase tracking-wider">Exceptions</p>
          <p class="text-sm font-display font-bold" id="hp-exceptions">—</p>
        </div>
      </div>

    </div>
  </div>
  <p class="text-text-tertiary text-xs mt-3 text-center italic">
    The happy path is not the workflow. It is the least interesting version of the workflow.
  </p>
</div>

<script>
const canvas = document.getElementById('hp-canvas') as HTMLCanvasElement;
const btnHappy = document.getElementById('hp-happy') as HTMLButtonElement;
const btnReal = document.getElementById('hp-real') as HTMLButtonElement;

if (canvas && btnHappy && btnReal) {
  const ctx = canvas.getContext('2d')!;
  let mode: 'happy' | 'real' = 'happy';
  let animId = 0;

  const GREEN: [number, number, number] = [74, 222, 128];
  const RED: [number, number, number] = [239, 68, 68];
  const AMBER: [number, number, number] = [245, 158, 11];
  const BLUE: [number, number, number] = [56, 189, 248];
  const VIOLET: [number, number, number] = [167, 139, 250];

  function resize() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function drawNode(x: number, y: number, r: number, label: string, color: [number, number, number], alpha: number) {
    const [cr, cg, cb] = color;
    ctx.beginPath();
    ctx.arc(x, y, r, 0, Math.PI * 2);
    ctx.fillStyle = `rgba(${cr},${cg},${cb},${alpha * 0.08})`;
    ctx.fill();
    ctx.strokeStyle = `rgba(${cr},${cg},${cb},${alpha * 0.5})`;
    ctx.lineWidth = 1.5;
    ctx.stroke();

    const isNarrow = canvas.clientWidth < 500;
    ctx.font = `600 ${isNarrow ? 8 : 9}px "Syne", system-ui`;
    ctx.fillStyle = `rgba(232,232,240,${alpha * 0.85})`;
    ctx.textAlign = 'center';
    ctx.textBaseline = 'middle';
    const lines = label.split('\n');
    lines.forEach((line, i) => {
      ctx.fillText(line, x, y + (i - (lines.length - 1) / 2) * 11);
    });
    ctx.textBaseline = 'alphabetic';
  }

  function drawEdge(x1: number, y1: number, x2: number, y2: number, color: [number, number, number], alpha: number, dashed: boolean) {
    const [cr, cg, cb] = color;
    ctx.beginPath();
    ctx.moveTo(x1, y1);
    ctx.lineTo(x2, y2);
    ctx.strokeStyle = `rgba(${cr},${cg},${cb},${alpha})`;
    ctx.lineWidth = 1.2;
    if (dashed) ctx.setLineDash([4, 4]);
    ctx.stroke();
    ctx.setLineDash([]);
  }

  function render(now: number) {
    const w = canvas.clientWidth;
    const h = canvas.clientHeight;
    const t = now * 0.001;
    const isNarrow = w < 500;
    const nr = isNarrow ? 16 : 20;
    const snr = isNarrow ? 11 : 13;

    ctx.clearRect(0, 0, w, h);

    const cx = w / 2;

    if (mode === 'happy') {
      // Clean 3-step vertical flow, centred
      const steps = ['Submit', 'Approve', 'Complete'];
      const topY = 60;
      const spacing = (h - 100) / 2;

      for (let i = 0; i < 3; i++) {
        const y = topY + i * spacing;
        if (i < 2) {
          const ny = topY + (i + 1) * spacing;
          drawEdge(cx, y + nr, cx, ny - nr, GREEN, 0.25, false);
          // Particle
          const pt = ((t * 0.15 + i * 0.4) % 1);
          const py = (y + nr) + (ny - nr - y - nr) * pt;
          ctx.beginPath();
          ctx.arc(cx, py, 2, 0, Math.PI * 2);
          ctx.fillStyle = 'rgba(74,222,128,0.5)';
          ctx.fill();
        }
        drawNode(cx, y, nr, steps[i], GREEN, 0.9);
      }

      ctx.font = `400 ${isNarrow ? 8 : 9}px "Inter", system-ui`;
      ctx.fillStyle = 'rgba(74,222,128,0.4)';
      ctx.textAlign = 'center';
      ctx.fillText('Three steps. No exceptions. No branches.', cx, h - 15);

    } else {
      // Real process — full complexity
      const topY = 45;
      const spacing = isNarrow ? 38 : 42;
      const branchX = isNarrow ? w * 0.28 : w * 0.3;

      // Main spine nodes
      const spine: { x: number; y: number; label: string; color: [number, number, number]; r: number }[] = [
        { x: cx, y: topY, label: 'Submit', color: VIOLET, r: nr },
        { x: cx, y: topY + spacing, label: isNarrow ? 'Review' : 'Under review', color: BLUE, r: nr },
        { x: cx, y: topY + spacing * 2, label: isNarrow ? 'Evidence\nresubmit' : 'Evidence resubmitted', color: AMBER, r: nr - 2 },
        { x: cx, y: topY + spacing * 3, label: isNarrow ? 'Delegated\nreview' : 'Delegated review', color: BLUE, r: nr - 2 },
        { x: cx, y: topY + spacing * 4, label: isNarrow ? 'Partial\napproval' : 'Partial approval', color: AMBER, r: nr - 2 },
        { x: cx, y: topY + spacing * 5, label: 'Resume', color: GREEN, r: nr - 2 },
        { x: cx, y: topY + spacing * 6, label: 'Approve', color: GREEN, r: nr },
        { x: cx, y: topY + spacing * 7, label: 'Complete', color: GREEN, r: nr },
      ];

      // Spine edges
      for (let i = 0; i < spine.length - 1; i++) {
        const a = spine[i];
        const b = spine[i + 1];
        drawEdge(a.x, a.y + a.r, b.x, b.y - b.r, b.color, 0.2, false);
      }

      // Draw spine nodes
      for (const n of spine) {
        drawNode(n.x, n.y, n.r, n.label, n.color, 0.85);
      }

      // Branch: Evidence missing warning (from review)
      const evX = cx - branchX;
      const evY = spine[1].y + 10;
      drawEdge(spine[1].x - spine[1].r, spine[1].y, evX + snr, evY, AMBER, 0.3, true);
      drawNode(evX, evY, snr, isNarrow ? 'Evidence\nmissing' : 'Evidence missing', AMBER, 0.7);

      // Branch: Authority expired (from review)
      const authX = cx + branchX;
      const authY = spine[1].y + 10;
      drawEdge(spine[1].x + spine[1].r, spine[1].y, authX - snr, authY, RED, 0.3, true);
      drawNode(authX, authY, snr, isNarrow ? 'Authority\nexpired' : 'Authority expired', RED, 0.7);

      // Return arrow from review back to submit
      ctx.beginPath();
      const retX = cx - branchX * 0.6;
      ctx.moveTo(spine[1].x - spine[1].r, spine[1].y - 5);
      ctx.quadraticCurveTo(retX, (spine[0].y + spine[1].y) / 2, spine[0].x - spine[0].r, spine[0].y + 5);
      ctx.strokeStyle = 'rgba(239,68,68,0.25)';
      ctx.lineWidth = 1;
      ctx.setLineDash([4, 4]);
      ctx.stroke();
      ctx.setLineDash([]);

      ctx.font = `500 ${isNarrow ? 6 : 7}px "JetBrains Mono", monospace`;
      ctx.fillStyle = 'rgba(239,68,68,0.5)';
      ctx.textAlign = 'center';
      ctx.fillText('RETURN', retX - 4, (spine[0].y + spine[1].y) / 2 - 3);

      // Branch: Paused for external input (from partial approval)
      const pauseX = cx + branchX;
      const pauseY = spine[4].y + 10;
      drawEdge(spine[4].x + spine[4].r, spine[4].y, pauseX - snr, pauseY, BLUE, 0.3, true);
      drawNode(pauseX, pauseY, snr, isNarrow ? 'Paused' : 'Paused — external', BLUE, 0.7);

      ctx.font = `400 ${isNarrow ? 8 : 9}px "Inter", system-ui`;
      ctx.fillStyle = 'rgba(239,68,68,0.4)';
      ctx.textAlign = 'center';
      ctx.fillText('Eight steps. Three branches. Two warnings. One return.', cx, h - 15);
    }

    animId = requestAnimationFrame(render);
  }

  function updateMetrics(m: 'happy' | 'real') {
    const s = document.getElementById('hp-steps')!;
    const b = document.getElementById('hp-branches')!;
    const e = document.getElementById('hp-exceptions')!;
    if (m === 'happy') {
      s.textContent = '3'; s.style.color = 'rgba(74,222,128,0.8)';
      b.textContent = '0'; b.style.color = 'rgba(74,222,128,0.8)';
      e.textContent = '0'; e.style.color = 'rgba(74,222,128,0.8)';
    } else {
      s.textContent = '8'; s.style.color = 'rgba(245,158,11,0.8)';
      b.textContent = '3'; b.style.color = 'rgba(239,68,68,0.8)';
      e.textContent = '2'; e.style.color = 'rgba(239,68,68,0.8)';
    }
  }

  function setMode(m: 'happy' | 'real') {
    mode = m;
    updateMetrics(m);
    btnHappy.setAttribute('aria-selected', String(m === 'happy'));
    btnReal.setAttribute('aria-selected', String(m === 'real'));
    if (m === 'happy') {
      btnHappy.style.background = 'rgba(74,222,128,0.12)';
      btnHappy.style.color = 'rgba(74,222,128,0.9)';
      btnHappy.style.borderColor = 'rgba(74,222,128,0.3)';
      btnReal.style.background = 'transparent';
      btnReal.style.color = 'rgba(232,232,240,0.3)';
      btnReal.style.borderColor = 'rgba(255,255,255,0.06)';
    } else {
      btnReal.style.background = 'rgba(239,68,68,0.12)';
      btnReal.style.color = 'rgba(239,68,68,0.9)';
      btnReal.style.borderColor = 'rgba(239,68,68,0.3)';
      btnHappy.style.background = 'transparent';
      btnHappy.style.color = 'rgba(232,232,240,0.3)';
      btnHappy.style.borderColor = 'rgba(255,255,255,0.06)';
    }
  }

  btnHappy.addEventListener('click', () => setMode('happy'));
  btnReal.addEventListener('click', () => setMode('real'));

  resize();
  updateMetrics('happy');
  window.addEventListener('resize', resize);
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    animId = requestAnimationFrame(render);
  } else { render(5000); }
}
</script>
