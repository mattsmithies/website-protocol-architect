---
// Visual 1: Authority windows over time
// Interactive timeline with pointer-driven "now" cursor and live status panel
---

<div class="reveal my-12 md:my-16">
  <div class="rounded-2xl border border-border overflow-hidden" style="background: rgba(11,11,17,0.6);">
    <div class="flex flex-col lg:flex-row">
      <canvas
        id="auth-timeline"
        class="flex-1"
        style="height: 380px; cursor: crosshair;"
      ></canvas>
      <div
        id="auth-timeline-panel"
        class="lg:w-64 p-6 border-t lg:border-t-0 lg:border-l border-border text-sm lg:min-h-[380px]"
      >
        <p class="text-text-tertiary text-xs font-semibold tracking-[0.2em] uppercase mb-4">At this moment</p>
        <div id="atp-valid" class="mb-3">
          <span class="text-text-tertiary text-xs">Valid authority</span>
          <span class="text-text-primary font-display font-bold text-lg block" id="atp-valid-count">—</span>
        </div>
        <div id="atp-expired" class="mb-3">
          <span class="text-text-tertiary text-xs">Expired authority</span>
          <span class="text-text-primary font-display font-bold text-lg block" id="atp-expired-count">—</span>
        </div>
        <div id="atp-broken" class="mb-4">
          <span class="text-text-tertiary text-xs">Broken delegation chains</span>
          <span class="text-text-primary font-display font-bold text-lg block" id="atp-broken-count">—</span>
        </div>
        <div class="border-t border-border pt-4">
          <p class="text-xs text-text-tertiary mb-2">Permitted</p>
          <p class="text-xs text-green-400/70 font-mono leading-relaxed min-h-[60px]" id="atp-permitted">—</p>
          <p class="text-xs text-text-tertiary mt-3 mb-2">Denied</p>
          <p class="text-xs text-red-400/70 font-mono leading-relaxed min-h-[40px]" id="atp-denied">—</p>
        </div>
      </div>
    </div>
  </div>
  <p class="text-text-tertiary text-xs mt-3 text-center italic">
    Authority is not a label attached to a person. It is a validity window attached to a claim.
  </p>
</div>

<script>
const canvas = document.getElementById('auth-timeline') as HTMLCanvasElement;
if (canvas) {
  const ctx = canvas.getContext('2d')!;

  const VIOLET = [167, 139, 250];
  const BLUE = [56, 189, 248];
  const GREEN = [74, 222, 128];
  const RED = [239, 68, 68];
  const AMBER = [245, 158, 11];

  interface AuthWindow {
    role: string;
    start: number;
    end: number;
    color: number[];
    row: number;
    delegatedFrom?: number;
    actions: string[];
  }

  const windows: AuthWindow[] = [
    { role: 'Board Signatory', start: 0.0, end: 0.85, color: VIOLET, row: 0, actions: ['Approve budget', 'Sign contracts'] },
    { role: 'Programme Director', start: 0.05, end: 0.65, color: BLUE, row: 1, actions: ['Approve budget', 'Release funds'] },
    { role: 'Delegated Approver', start: 0.15, end: 0.45, color: GREEN, row: 2, delegatedFrom: 1, actions: ['Approve budget'] },
    { role: 'Delegated Approver', start: 0.50, end: 0.70, color: GREEN, row: 2, delegatedFrom: 1, actions: ['Approve budget'] },
    { role: 'Auditor Access', start: 0.30, end: 0.90, color: BLUE, row: 3, actions: ['View audit logs'] },
    { role: 'Emergency Override', start: 0.60, end: 0.68, color: RED, row: 4, actions: ['Emergency override'] },
  ];

  let cursorT = -1;
  let animId = 0;
  let animCursor = 0;

  function resize() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function getLayout() {
    const w = canvas.clientWidth;
    const h = canvas.clientHeight;
    const marginLeft = w < 500 ? 10 : 145;
    const marginRight = 25;
    const marginTop = 35;
    const rowHeight = (h - marginTop - 35) / 5;
    const timelineWidth = w - marginLeft - marginRight;
    return { w, h, marginLeft, marginRight, marginTop, rowHeight, timelineWidth };
  }

  function updatePanel(t: number) {
    let valid = 0, expired = 0, broken = 0;
    const permitted: string[] = [];
    const denied: string[] = [];

    const allActions = new Set<string>();
    windows.forEach(w => w.actions.forEach(a => allActions.add(a)));

    const activeActions = new Set<string>();

    for (const win of windows) {
      if (t >= win.start && t <= win.end) {
        valid++;
        win.actions.forEach(a => activeActions.add(a));
      } else if (t > win.end) {
        expired++;
      }
    }

    // Check delegation gap
    const delegatedWindows = windows.filter(w => w.row === 2);
    const inGap = delegatedWindows.every(dw => t < dw.start || t > dw.end) && t > delegatedWindows[0].start && t < (delegatedWindows[1]?.end ?? 1);
    if (inGap && t > delegatedWindows[0].end && t < (delegatedWindows[1]?.start ?? 1)) broken = 1;

    for (const action of allActions) {
      if (activeActions.has(action)) permitted.push(action);
      else denied.push(action);
    }

    const el = (id: string) => document.getElementById(id);
    const vc = el('atp-valid-count');
    const ec = el('atp-expired-count');
    const bc = el('atp-broken-count');
    const pp = el('atp-permitted');
    const dp = el('atp-denied');

    if (vc) vc.textContent = String(valid);
    if (ec) ec.textContent = String(expired);
    if (bc) bc.textContent = String(broken);
    if (pp) pp.textContent = permitted.length > 0 ? permitted.join('\n') : 'None';
    if (dp) dp.textContent = denied.length > 0 ? denied.join('\n') : 'None';

    if (ec) ec.style.color = expired > 0 ? 'rgba(239,68,68,0.8)' : '';
    if (bc) bc.style.color = broken > 0 ? 'rgba(245,158,11,0.9)' : '';
  }

  function render(now: number) {
    const { w, h, marginLeft, marginRight, marginTop, rowHeight, timelineWidth } = getLayout();

    // Animate cursor if no mouse interaction
    if (cursorT < 0) {
      animCursor = ((now * 0.00003) % 1.15) - 0.05;
    }

    const t = cursorT >= 0 ? cursorT : animCursor;

    ctx.clearRect(0, 0, w, h);

    // Time axis
    ctx.strokeStyle = 'rgba(255,255,255,0.06)';
    ctx.lineWidth = 1;
    ctx.beginPath();
    ctx.moveTo(marginLeft, h - 28);
    ctx.lineTo(w - marginRight, h - 28);
    ctx.stroke();

    // Time labels
    ctx.font = '400 9px "JetBrains Mono", monospace';
    ctx.fillStyle = 'rgba(232,232,240,0.2)';
    ctx.textAlign = 'center';
    for (let i = 0; i <= 4; i++) {
      const tx = i / 4;
      const x = marginLeft + tx * timelineWidth;
      ctx.fillText(`T+${i * 3}mo`, x, h - 14);
      if (i > 0 && i < 4) {
        ctx.beginPath();
        ctx.moveTo(x, marginTop);
        ctx.lineTo(x, h - 28);
        ctx.strokeStyle = 'rgba(255,255,255,0.03)';
        ctx.stroke();
      }
    }

    // Cursor line
    if (t >= 0 && t <= 1) {
      const cx = marginLeft + t * timelineWidth;
      ctx.beginPath();
      ctx.moveTo(cx, marginTop - 8);
      ctx.lineTo(cx, h - 28);
      ctx.strokeStyle = 'rgba(167,139,250,0.35)';
      ctx.lineWidth = 1;
      ctx.setLineDash([4, 4]);
      ctx.stroke();
      ctx.setLineDash([]);

      ctx.font = '500 9px "Syne", system-ui';
      ctx.fillStyle = 'rgba(167,139,250,0.7)';
      ctx.textAlign = 'center';
      ctx.fillText(cursorT >= 0 ? 'ACTION TIME' : 'NOW', cx, marginTop - 12);

      updatePanel(t);
    }

    // Authority windows
    for (const win of windows) {
      const [r, g, b] = win.color;
      const y = marginTop + win.row * rowHeight;
      const x1 = marginLeft + win.start * timelineWidth;
      const x2 = marginLeft + win.end * timelineWidth;
      const barH = rowHeight * 0.48;

      const active = t >= win.start && t <= win.end;
      const expired = t > win.end && t <= 1;

      const alpha = active ? 0.22 : expired ? 0.04 : 0.08;
      ctx.fillStyle = `rgba(${r},${g},${b},${alpha})`;
      ctx.beginPath();
      ctx.roundRect(x1, y, x2 - x1, barH, 4);
      ctx.fill();

      ctx.strokeStyle = `rgba(${r},${g},${b},${active ? 0.55 : 0.12})`;
      ctx.lineWidth = active ? 1.5 : 0.75;
      ctx.stroke();

      if (active) {
        ctx.shadowColor = `rgba(${r},${g},${b},0.25)`;
        ctx.shadowBlur = 10;
        ctx.stroke();
        ctx.shadowBlur = 0;
      }

      if (expired && t <= 1) {
        ctx.font = '400 7px "JetBrains Mono", monospace';
        ctx.fillStyle = 'rgba(239,68,68,0.45)';
        ctx.textAlign = 'left';
        ctx.fillText('EXPIRED', x2 + 6, y + barH / 2 + 3);
      }

      if (w >= 500) {
        ctx.font = '500 10px "Syne", system-ui';
        ctx.fillStyle = `rgba(${r},${g},${b},${active ? 0.85 : 0.35})`;
        ctx.textAlign = 'right';
        ctx.textBaseline = 'middle';
        ctx.fillText(win.role, marginLeft - 12, y + barH / 2);
        ctx.textBaseline = 'alphabetic';
      }

      // Delegation arrow
      if (win.delegatedFrom !== undefined) {
        const fromY = marginTop + win.delegatedFrom * rowHeight + rowHeight * 0.48;
        ctx.beginPath();
        ctx.moveTo(x1, fromY);
        ctx.lineTo(x1, y);
        ctx.strokeStyle = `rgba(${r},${g},${b},0.15)`;
        ctx.lineWidth = 0.75;
        ctx.setLineDash([3, 3]);
        ctx.stroke();
        ctx.setLineDash([]);
      }
    }

    // Gap warning
    const gap1End = windows[2].end;
    const gap2Start = windows[3].start;
    if (t >= gap1End && t <= gap2Start) {
      const gx1 = marginLeft + gap1End * timelineWidth;
      const gx2 = marginLeft + gap2Start * timelineWidth;
      const gy = marginTop + 2 * rowHeight;
      const gBarH = rowHeight * 0.48;
      ctx.fillStyle = 'rgba(245,158,11,0.06)';
      ctx.fillRect(gx1, gy, gx2 - gx1, gBarH);
      ctx.font = '600 8px "Syne", system-ui';
      ctx.fillStyle = 'rgba(245,158,11,0.7)';
      ctx.textAlign = 'center';
      ctx.fillText('AUTHORITY GAP', (gx1 + gx2) / 2, gy + gBarH / 2 + 3);
    }

    animId = requestAnimationFrame(render);
  }

  canvas.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    const { marginLeft, timelineWidth } = getLayout();
    cursorT = Math.max(0, Math.min(1, (e.clientX - rect.left - marginLeft) / timelineWidth));
  });

  canvas.addEventListener('mouseleave', () => { cursorT = -1; });

  resize();
  window.addEventListener('resize', resize);

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    animId = requestAnimationFrame(render);
  } else {
    render(8000);
  }
}
</script>
