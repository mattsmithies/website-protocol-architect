---
// Visual: Current state versus replayed state
// Split view with slider — left shows static summary, right replays history step by step
---

<div class="reveal my-12 md:my-16">
  <div class="rounded-2xl border border-border overflow-hidden" style="background: rgba(11,11,17,0.6);">
    <div class="p-6 md:p-8">

      <!-- Replay scrubber -->
      <div class="mb-6">
        <label for="cvrs-scrubber" class="sr-only">Replay progress</label>
        <input
          id="cvrs-scrubber"
          type="range" min="0" max="6" value="0" step="1"
          aria-label="Replay progress — scrub to reveal state transitions"
          aria-valuemin="0"
          aria-valuemax="6"
          aria-valuenow="0"
          class="w-full accent-signal h-1 bg-border rounded-full appearance-none cursor-pointer"
        />
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8">

        <!-- Left panel: Current state (always visible) -->
        <div>
          <p class="text-text-tertiary text-xs font-semibold tracking-[0.2em] uppercase mb-4">Current State</p>
          <div class="glass-card p-5">
            <div class="space-y-3">
              <div class="flex items-center justify-between">
                <span class="text-xs text-text-tertiary font-mono">Asset status</span>
                <span class="text-sm font-display font-semibold" style="color: rgba(74,222,128,0.85);">Issued</span>
              </div>
              <div class="border-t border-border"></div>
              <div class="flex items-center justify-between">
                <span class="text-xs text-text-tertiary font-mono">Approval</span>
                <span class="text-sm font-display font-semibold" style="color: rgba(74,222,128,0.85);">Approved</span>
              </div>
              <div class="border-t border-border"></div>
              <div class="flex items-center justify-between">
                <span class="text-xs text-text-tertiary font-mono">Owner</span>
                <span class="text-sm font-display font-semibold text-text-primary">Current holder</span>
              </div>
              <div class="border-t border-border"></div>
              <div class="flex items-center justify-between">
                <span class="text-xs text-text-tertiary font-mono">Risk tier</span>
                <span class="text-sm font-display font-semibold" style="color: rgba(74,222,128,0.85);">Low</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Right panel: Replay timeline -->
        <div>
          <p class="text-text-tertiary text-xs font-semibold tracking-[0.2em] uppercase mb-4">Replay Timeline</p>
          <div id="cvrs-replay" class="space-y-0" aria-live="polite"></div>
        </div>

      </div>

      <!-- Comparison footer -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 md:gap-8 mt-6 border-t border-border pt-4">
        <div>
          <p class="text-xs font-mono" style="color: rgba(245,158,11,0.75);">Summary only &mdash; path unknown</p>
        </div>
        <div>
          <p id="cvrs-status" class="text-xs font-mono" style="color: rgba(74,222,128,0.75);">Path reconstructable &mdash; 0 of 6 transitions visible</p>
        </div>
      </div>

    </div>
  </div>
  <p class="text-text-tertiary text-xs mt-3 text-center italic">
    Current state is a summary. Replayability preserves the path that made the summary meaningful.
  </p>
</div>

<script>
interface ReplayStep {
  label: string;
  color: 'violet' | 'blue' | 'red' | 'amber' | 'green';
}

const steps: ReplayStep[] = [
  { label: 'Submitted by Actor A', color: 'violet' },
  { label: 'Evidence attached', color: 'blue' },
  { label: 'Returned for correction', color: 'red' },
  { label: 'Delegated approval to Actor B', color: 'amber' },
  { label: 'Signature added', color: 'green' },
  { label: 'State updated \u2014 asset issued', color: 'green' },
];

const colorMap: Record<string, { border: string; bg: string; text: string }> = {
  violet: { border: 'rgba(167,139,250,0.5)', bg: 'rgba(167,139,250,0.06)', text: 'rgba(167,139,250,0.8)' },
  blue:   { border: 'rgba(56,189,248,0.5)',  bg: 'rgba(56,189,248,0.06)',  text: 'rgba(56,189,248,0.8)' },
  red:    { border: 'rgba(239,68,68,0.5)',   bg: 'rgba(239,68,68,0.06)',   text: 'rgba(239,68,68,0.8)' },
  amber:  { border: 'rgba(245,158,11,0.5)',  bg: 'rgba(245,158,11,0.06)',  text: 'rgba(245,158,11,0.8)' },
  green:  { border: 'rgba(74,222,128,0.5)',  bg: 'rgba(74,222,128,0.06)',  text: 'rgba(74,222,128,0.8)' },
};

const scrubber = document.getElementById('cvrs-scrubber') as HTMLInputElement;
const replayEl = document.getElementById('cvrs-replay')!;
const statusEl = document.getElementById('cvrs-status')!;

function renderReplay(visibleCount: number) {
  replayEl.innerHTML = steps.map((step, i) => {
    const visible = i < visibleCount;
    const isCurrent = i === visibleCount - 1;
    const c = colorMap[step.color];
    const opacity = visible ? (isCurrent ? 1 : 0.55) : 0;
    const transform = visible ? 'translateY(0)' : 'translateY(8px)';
    const borderLeft = visible ? (isCurrent ? c.border : c.border.replace('0.5', '0.25')) : 'rgba(255,255,255,0.06)';

    return `
      <div class="py-3 pl-4 ${i < steps.length - 1 ? 'border-b border-border' : ''}" style="opacity: ${opacity}; transform: ${transform}; border-left: 3px solid ${borderLeft}; background: ${isCurrent ? c.bg : 'transparent'}; transition: opacity 0.4s, transform 0.4s, background 0.3s, border-color 0.3s;">
        <div class="flex items-center gap-2">
          <span class="font-mono text-xs text-text-tertiary" style="min-width: 20px;">${i + 1}.</span>
          <span class="text-sm font-display font-semibold" style="color: ${visible ? (isCurrent ? c.text : 'rgba(232,232,240,0.55)') : 'rgba(232,232,240,0.15)'}; transition: color 0.3s;">${step.label}</span>
        </div>
      </div>
    `;
  }).join('');

  statusEl.textContent = `Path reconstructable \u2014 ${visibleCount} of 6 transitions visible`;
}

if (scrubber) {
  scrubber.addEventListener('input', () => {
    const val = parseInt(scrubber.value);
    scrubber.setAttribute('aria-valuenow', String(val));
    renderReplay(val);
  });
  renderReplay(0);
}
</script>
