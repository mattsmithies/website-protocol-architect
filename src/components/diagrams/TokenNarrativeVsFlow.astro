---
// Visual 1: Token story vs Token flow — side by side comparison
---

<div class="reveal my-12 md:my-16">
  <div class="rounded-2xl border border-border overflow-hidden" style="background: rgba(11,11,17,0.6);">
    <div class="grid grid-cols-1 md:grid-cols-2 divide-y md:divide-y-0 md:divide-x divide-border">

      {/* Left: Narrative token */}
      <div class="p-6 md:p-8">
        <p class="text-red-400/70 text-xs font-semibold tracking-[0.2em] uppercase mb-5">Narrative Token</p>
        <canvas id="tnf-narrative" class="w-full" style="height: 380px;" role="img" aria-label="Narrative token flow — value moves from treasury through rewards to users then exits via exchanges"></canvas>
      </div>

      {/* Right: Demand sink token */}
      <div class="p-6 md:p-8">
        <p class="text-green-400/70 text-xs font-semibold tracking-[0.2em] uppercase mb-5">Demand Sink Token</p>
        <canvas id="tnf-demand" class="w-full" style="height: 380px;" role="img" aria-label="Demand sink token flow — value cycles through required network actions and contributors, reinforcing the network"></canvas>
      </div>

    </div>
  </div>
  <p class="text-text-tertiary text-xs mt-3 text-center italic">
    The question is not whether a token moves. The question is whether it returns with more reason to exist than before.
  </p>
</div>

<script>
function drawTokenFlow(canvasId: string, type: 'narrative' | 'demand') {
  const canvas = document.getElementById(canvasId) as HTMLCanvasElement;
  if (!canvas) return;
  const ctx = canvas.getContext('2d')!;

  const RED = [239, 68, 68];
  const GREEN = [74, 222, 128];
  const BLUE = [56, 189, 248];
  const VIOLET = [167, 139, 250];
  const AMBER = [245, 158, 11];
  const DIM = [120, 120, 140];

  interface FNode { x: number; y: number; label: string; color: number[]; halfW: number; halfH: number; }
  interface FEdge { from: number; to: number; color: number[]; label: string; type: 'leak' | 'sink' | 'reinforce' | 'neutral'; }

  let nodes: FNode[] = [];
  let edges: FEdge[] = [];
  let animId = 0;

  function resize() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function measureNode(label: string): { halfW: number; halfH: number } {
    ctx.font = '600 13px "Syne", system-ui';
    const tw = ctx.measureText(label).width;
    return { halfW: tw / 2 + 18, halfH: 16 };
  }

  function build() {
    const w = canvas.clientWidth;
    const h = canvas.clientHeight;
    const cx = w * 0.38;
    const step = (h - 70) / 4;

    if (type === 'narrative') {
      const raw = [
        { x: cx, y: 40, label: 'Treasury', color: VIOLET },
        { x: cx, y: 40 + step, label: 'Rewards', color: AMBER },
        { x: cx, y: 40 + step * 2, label: 'Users', color: DIM },
        { x: cx, y: 40 + step * 3, label: 'Exchange', color: RED },
        { x: cx, y: 40 + step * 4, label: 'Sell', color: RED },
      ];
      nodes = raw.map(n => ({ ...n, ...measureNode(n.label) }));
      edges = [
        { from: 0, to: 1, color: VIOLET, label: 'Emission', type: 'neutral' },
        { from: 1, to: 2, color: AMBER, label: 'Distribute', type: 'neutral' },
        { from: 2, to: 3, color: RED, label: 'Dump', type: 'leak' },
        { from: 3, to: 4, color: RED, label: 'Exit', type: 'leak' },
      ];
    } else {
      const raw = [
        { x: cx, y: 40, label: 'Buyers', color: BLUE },
        { x: cx, y: 40 + step, label: 'Token', color: VIOLET },
        { x: cx, y: 40 + step * 2, label: 'Network Action', color: GREEN },
        { x: cx, y: 40 + step * 3, label: 'Contributors', color: GREEN },
        { x: cx, y: 40 + step * 4, label: 'Better Network', color: BLUE },
      ];
      nodes = raw.map(n => ({ ...n, ...measureNode(n.label) }));
      edges = [
        { from: 0, to: 1, color: BLUE, label: 'Acquire', type: 'sink' },
        { from: 1, to: 2, color: GREEN, label: 'Required spend', type: 'sink' },
        { from: 2, to: 3, color: GREEN, label: 'Redistribute', type: 'reinforce' },
        { from: 3, to: 4, color: BLUE, label: 'Improve', type: 'reinforce' },
        { from: 4, to: 0, color: BLUE, label: 'Attract', type: 'reinforce' },
      ];
    }
  }

  function render(now: number) {
    const w = canvas.clientWidth;
    const h = canvas.clientHeight;
    const t = now * 0.001;
    ctx.clearRect(0, 0, w, h);

    const typeColors: Record<string, string> = {
      leak: `rgba(239,68,68,0.45)`,
      sink: `rgba(74,222,128,0.45)`,
      reinforce: `rgba(56,189,248,0.45)`,
      neutral: `rgba(167,139,250,0.35)`,
    };

    // Edges (behind nodes)
    for (let i = 0; i < edges.length; i++) {
      const e = edges[i];
      const a = nodes[e.from];
      const b = nodes[e.to];
      const [r, g, bl] = e.color;

      // Skip the feedback loop edge (last edge in demand mode) — drawn separately
      if (type === 'demand' && i === edges.length - 1) continue;

      const y1 = a.y + a.halfH;
      const y2 = b.y - b.halfH;

      // Subtle flow line
      ctx.beginPath();
      ctx.moveTo(a.x, y1);
      ctx.lineTo(b.x, y2);
      ctx.strokeStyle = `rgba(${r},${g},${bl},0.12)`;
      ctx.lineWidth = 1.5;
      ctx.stroke();

      // Small directional chevron at midpoint
      const mx = (a.x + b.x) / 2;
      const my = (y1 + y2) / 2;
      const chevSize = 4;
      ctx.beginPath();
      ctx.moveTo(mx - chevSize, my - chevSize);
      ctx.lineTo(mx, my);
      ctx.lineTo(mx + chevSize, my - chevSize);
      ctx.strokeStyle = `rgba(${r},${g},${bl},0.25)`;
      ctx.lineWidth = 1.2;
      ctx.stroke();

      // Subtle particle
      const pt = ((t * 0.2 + i * 0.2) % 1);
      const py = y1 + (y2 - y1) * pt;
      ctx.beginPath();
      ctx.arc(a.x + (b.x - a.x) * pt, py, 2, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(${r},${g},${bl},0.4)`;
      ctx.fill();

      // Edge label — inline beside flow line
      ctx.font = '400 11px "Inter", system-ui';
      ctx.fillStyle = typeColors[e.type];
      ctx.textAlign = 'left';
      ctx.fillText(e.label, mx + 10, my + 4);
    }

    // Feedback loop for demand model
    if (type === 'demand') {
      const e = edges[edges.length - 1];
      const a = nodes[e.from];
      const b = nodes[e.to];
      const [r, g, bl] = e.color;

      ctx.beginPath();
      ctx.moveTo(a.x + a.halfW + 6, a.y);
      ctx.quadraticCurveTo(w - 16, (a.y + b.y) / 2, b.x + b.halfW + 6, b.y);
      ctx.strokeStyle = `rgba(${r},${g},${bl},0.10)`;
      ctx.lineWidth = 1.5;
      ctx.setLineDash([5, 5]);
      ctx.stroke();
      ctx.setLineDash([]);

      // Label on curve
      ctx.font = '400 10px "Inter", system-ui';
      ctx.fillStyle = `rgba(${r},${g},${bl},0.35)`;
      ctx.textAlign = 'center';
      ctx.fillText(e.label, w - 22, (a.y + b.y) / 2);
    }

    // Nodes — rounded rectangles
    for (const node of nodes) {
      const [r, g, bl] = node.color;
      const { x, y, halfW, halfH } = node;

      // Glow
      const grad = ctx.createRadialGradient(x, y, 0, x, y, halfW * 1.8);
      grad.addColorStop(0, `rgba(${r},${g},${bl},0.06)`);
      grad.addColorStop(1, `rgba(${r},${g},${bl},0)`);
      ctx.fillStyle = grad;
      ctx.beginPath();
      ctx.arc(x, y, halfW * 1.8, 0, Math.PI * 2);
      ctx.fill();

      // Rounded rect
      ctx.beginPath();
      ctx.roundRect(x - halfW, y - halfH, halfW * 2, halfH * 2, 8);
      ctx.fillStyle = `rgba(${r},${g},${bl},0.06)`;
      ctx.fill();
      ctx.strokeStyle = `rgba(${r},${g},${bl},0.35)`;
      ctx.lineWidth = 1.5;
      ctx.stroke();

      // Label
      ctx.font = '600 13px "Syne", system-ui';
      ctx.fillStyle = `rgba(232,232,240,0.85)`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(node.label, x, y);
      ctx.textBaseline = 'alphabetic';
    }

    animId = requestAnimationFrame(render);
  }

  resize();
  build();
  window.addEventListener('resize', () => { resize(); build(); });
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    animId = requestAnimationFrame(render);
  } else { render(5000); }
}

drawTokenFlow('tnf-narrative', 'narrative');
drawTokenFlow('tnf-demand', 'demand');
</script>
