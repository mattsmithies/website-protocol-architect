---
// Visual: Anchor vs Fact Package
// Toggle between anchor-only and fact package to see what each actually proves
---

<div class="reveal my-12 md:my-16">
  <div class="rounded-2xl border border-border overflow-hidden" style="background: rgba(11,11,17,0.6);">
    <div class="p-6 md:p-8">

      <!-- Toggle -->
      <div class="flex items-center justify-center gap-3 mb-6" role="tablist" aria-label="Toggle between anchor only and fact package modes">
        <button id="avf-anchor" class="px-4 py-2 rounded-full text-xs font-display font-semibold transition-all duration-300 cursor-pointer" role="tab" aria-selected="true" style="background: rgba(239,68,68,0.15); color: rgba(239,68,68,0.9); border: 1px solid rgba(239,68,68,0.3);">
          Anchor only
        </button>
        <button id="avf-fact" class="px-4 py-2 rounded-full text-xs font-display font-semibold transition-all duration-300 cursor-pointer" role="tab" aria-selected="false" style="background: transparent; color: rgba(232,232,240,0.3); border: 1px solid rgba(255,255,255,0.06);">
          Fact package
        </button>
      </div>

      <!-- Card content -->
      <div class="max-w-2xl mx-auto">

        <!-- Anchor only card -->
        <div id="avf-card-anchor" class="glass-card p-5 md:p-6">
          <div class="space-y-3">
            <div class="flex items-baseline gap-3">
              <span class="text-[10px] text-text-tertiary uppercase tracking-wider font-semibold w-28 flex-shrink-0">Hash posted</span>
              <span class="text-sm font-mono text-text-secondary">0x7a3f...9c21</span>
            </div>
            <div class="flex items-baseline gap-3">
              <span class="text-[10px] text-text-tertiary uppercase tracking-wider font-semibold w-28 flex-shrink-0">Timestamp</span>
              <span class="text-sm font-mono text-text-secondary">2024-05-21 09:23 UTC</span>
            </div>
            <div class="flex items-baseline gap-3">
              <span class="text-[10px] text-text-tertiary uppercase tracking-wider font-semibold w-28 flex-shrink-0">Chain reference</span>
              <span class="text-sm font-mono text-text-secondary">Block 14,291,003</span>
            </div>
          </div>
        </div>

        <!-- Fact package card (hidden by default) -->
        <div id="avf-card-fact" class="glass-card p-5 md:p-6" style="display: none;">
          <div class="space-y-3">
            <div class="flex items-baseline gap-3">
              <span class="text-[10px] text-text-tertiary uppercase tracking-wider font-semibold w-28 flex-shrink-0">Actor</span>
              <span class="text-sm font-mono text-text-secondary">Actor B <span class="text-text-tertiary">(delegated authority)</span></span>
            </div>
            <div class="flex items-baseline gap-3">
              <span class="text-[10px] text-text-tertiary uppercase tracking-wider font-semibold w-28 flex-shrink-0">Authority</span>
              <span class="text-sm font-mono text-text-secondary">Valid delegation from Actor A, expires 22 June</span>
            </div>
            <div class="flex items-baseline gap-3">
              <span class="text-[10px] text-text-tertiary uppercase tracking-wider font-semibold w-28 flex-shrink-0">Evidence</span>
              <span class="text-sm font-mono text-text-secondary">3 documents bound to claim</span>
            </div>
            <div class="flex items-baseline gap-3">
              <span class="text-[10px] text-text-tertiary uppercase tracking-wider font-semibold w-28 flex-shrink-0">Content hash</span>
              <span class="text-sm font-mono text-text-secondary">SHA-256: 0x7a3f...9c21</span>
            </div>
            <div class="flex items-baseline gap-3">
              <span class="text-[10px] text-text-tertiary uppercase tracking-wider font-semibold w-28 flex-shrink-0">Signature</span>
              <span class="text-sm font-mono text-text-secondary">Ed25519 by key <span class="text-text-tertiary">did:key:z6Mk...</span></span>
            </div>
            <div class="flex items-baseline gap-3">
              <span class="text-[10px] text-text-tertiary uppercase tracking-wider font-semibold w-28 flex-shrink-0">Algorithm</span>
              <span class="text-sm font-mono text-text-secondary">Ed25519</span>
            </div>
            <div class="flex items-baseline gap-3">
              <span class="text-[10px] text-text-tertiary uppercase tracking-wider font-semibold w-28 flex-shrink-0">Challenge</span>
              <span class="text-sm font-mono text-text-secondary">Nonce n-4821 bound to action</span>
            </div>
            <div class="flex items-baseline gap-3">
              <span class="text-[10px] text-text-tertiary uppercase tracking-wider font-semibold w-28 flex-shrink-0">Public anchor</span>
              <span class="text-sm font-mono text-text-secondary">Block 14,291,003 <span class="text-text-tertiary">(optional, strengthens ordering)</span></span>
            </div>
          </div>
        </div>

        <!-- Status grid -->
        <div id="avf-status" class="mt-5 grid grid-cols-1 sm:grid-cols-5 gap-3" aria-live="polite">
        </div>

      </div>

    </div>
  </div>
  <p class="text-text-tertiary text-xs mt-3 text-center italic">
    An anchor proves that something was posted. It does not prove that the thing posted was true.
  </p>
</div>

<script>
interface StatusItem {
  label: string;
  anchorValue: string;
  anchorColor: string;
  factValue: string;
  factColor: string;
}

const statuses: StatusItem[] = [
  {
    label: 'Anchored',
    anchorValue: 'Yes',
    anchorColor: 'rgba(74,222,128,0.8)',
    factValue: 'Optional but useful',
    factColor: 'rgba(56,189,248,0.8)',
  },
  {
    label: 'Truth of fact',
    anchorValue: 'Unknown',
    anchorColor: 'rgba(239,68,68,0.8)',
    factValue: 'Checkable',
    factColor: 'rgba(74,222,128,0.8)',
  },
  {
    label: 'Origin',
    anchorValue: 'Unknown',
    anchorColor: 'rgba(239,68,68,0.8)',
    factValue: 'Attributable',
    factColor: 'rgba(74,222,128,0.8)',
  },
  {
    label: 'Authority',
    anchorValue: 'Unknown',
    anchorColor: 'rgba(239,68,68,0.8)',
    factValue: 'Checkable',
    factColor: 'rgba(74,222,128,0.8)',
  },
  {
    label: 'Evidence',
    anchorValue: 'Unknown',
    anchorColor: 'rgba(239,68,68,0.8)',
    factValue: 'Bound to claim',
    factColor: 'rgba(74,222,128,0.8)',
  },
];

const btnAnchor = document.getElementById('avf-anchor') as HTMLButtonElement;
const btnFact = document.getElementById('avf-fact') as HTMLButtonElement;
const cardAnchor = document.getElementById('avf-card-anchor') as HTMLElement;
const cardFact = document.getElementById('avf-card-fact') as HTMLElement;
const statusGrid = document.getElementById('avf-status') as HTMLElement;

let mode: 'anchor' | 'fact' = 'anchor';

function buildStatusGrid() {
  statusGrid.innerHTML = '';
  for (const item of statuses) {
    const value = mode === 'anchor' ? item.anchorValue : item.factValue;
    const color = mode === 'anchor' ? item.anchorColor : item.factColor;

    const cell = document.createElement('div');
    cell.className = 'rounded-lg p-3 border border-border transition-all duration-300';
    cell.style.background = 'rgba(11,11,17,0.5)';

    cell.innerHTML = `
      <p class="text-[10px] text-text-tertiary uppercase tracking-wider font-semibold mb-1">${item.label}</p>
      <p class="text-sm font-display font-bold transition-colors duration-300" style="color: ${color};">${value}</p>
    `;

    statusGrid.appendChild(cell);
  }
}

function setMode(m: 'anchor' | 'fact') {
  mode = m;

  if (m === 'anchor') {
    btnAnchor.setAttribute('aria-selected', 'true');
    btnAnchor.style.background = 'rgba(239,68,68,0.15)';
    btnAnchor.style.color = 'rgba(239,68,68,0.9)';
    btnAnchor.style.borderColor = 'rgba(239,68,68,0.3)';
    btnFact.setAttribute('aria-selected', 'false');
    btnFact.style.background = 'transparent';
    btnFact.style.color = 'rgba(232,232,240,0.3)';
    btnFact.style.borderColor = 'rgba(255,255,255,0.06)';

    cardAnchor.style.display = '';
    cardFact.style.display = 'none';
  } else {
    btnFact.setAttribute('aria-selected', 'true');
    btnFact.style.background = 'rgba(74,222,128,0.12)';
    btnFact.style.color = 'rgba(74,222,128,0.9)';
    btnFact.style.borderColor = 'rgba(74,222,128,0.3)';
    btnAnchor.setAttribute('aria-selected', 'false');
    btnAnchor.style.background = 'transparent';
    btnAnchor.style.color = 'rgba(232,232,240,0.3)';
    btnAnchor.style.borderColor = 'rgba(255,255,255,0.06)';

    cardAnchor.style.display = 'none';
    cardFact.style.display = '';
  }

  buildStatusGrid();
}

btnAnchor.addEventListener('click', () => setMode('anchor'));
btnFact.addEventListener('click', () => setMode('fact'));

// Initial render
buildStatusGrid();
</script>
