---
// Figure: Holder visible event history
// Three columns — Event, Metadata, Rights.
// Simple table-style layout. Standards-note tone.
// Message: a person should see when their identity or data was checked,
// understand the purpose, and have practical rights against the record.
---

<div class="reveal my-12 md:my-16">
  <div class="rounded-2xl border border-border overflow-hidden" style="background: rgba(11,11,17,0.6);">
    <div class="p-6 md:p-8">

      <div class="mb-6">
        <p class="text-text-tertiary text-xs font-semibold tracking-[0.2em] uppercase mb-1">Operational rights</p>
        <h3 class="text-text-primary font-display font-bold text-lg tracking-tight">Holder visible event history</h3>
      </div>

      <!-- Column headers -->
      <div class="grid grid-cols-3 gap-3 md:gap-5 mb-3 pb-3 border-b border-border/50">
        <p class="text-[10px] font-semibold tracking-[0.2em] uppercase text-text-tertiary">Event</p>
        <p class="text-[10px] font-semibold tracking-[0.2em] uppercase text-text-tertiary">Metadata</p>
        <p class="text-[10px] font-semibold tracking-[0.2em] uppercase text-text-tertiary">Rights</p>
      </div>

      <div class="grid grid-cols-3 gap-3 md:gap-5 text-sm">

        <!-- Event column -->
        <ul class="space-y-2 text-text-secondary">
          <li class="flex items-start gap-2">
            <span class="font-mono text-xs text-text-tertiary mt-0.5 shrink-0">·</span>
            <span>Identity checked</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="font-mono text-xs text-text-tertiary mt-0.5 shrink-0">·</span>
            <span>Attribute checked</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="font-mono text-xs text-text-tertiary mt-0.5 shrink-0">·</span>
            <span>Status checked</span>
          </li>
        </ul>

        <!-- Metadata column -->
        <ul class="space-y-2 text-text-secondary">
          <li class="flex items-start gap-2">
            <span class="font-mono text-xs text-text-tertiary mt-0.5 shrink-0">·</span>
            <span>Checker</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="font-mono text-xs text-text-tertiary mt-0.5 shrink-0">·</span>
            <span>Purpose</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="font-mono text-xs text-text-tertiary mt-0.5 shrink-0">·</span>
            <span>Timestamp</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="font-mono text-xs text-text-tertiary mt-0.5 shrink-0">·</span>
            <span>Retention period</span>
          </li>
        </ul>

        <!-- Rights column -->
        <ul class="space-y-2 text-text-secondary">
          <li class="flex items-start gap-2">
            <span class="font-mono text-xs text-text-tertiary mt-0.5 shrink-0">·</span>
            <span>View</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="font-mono text-xs text-text-tertiary mt-0.5 shrink-0">·</span>
            <span>Access</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="font-mono text-xs text-text-tertiary mt-0.5 shrink-0">·</span>
            <span>Challenge</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="font-mono text-xs text-text-tertiary mt-0.5 shrink-0">·</span>
            <span>Correct</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="font-mono text-xs text-text-tertiary mt-0.5 shrink-0">·</span>
            <span>Restrict</span>
          </li>
          <li class="flex items-start gap-2">
            <span class="font-mono text-xs text-text-tertiary mt-0.5 shrink-0">·</span>
            <span>Erase where applicable</span>
          </li>
        </ul>

      </div>

    </div>
  </div>
  <p class="text-text-tertiary text-xs mt-3 text-center italic">
    A person should be able to see when their identity or data was checked, by whom, for what purpose, and what rights apply to that record.
  </p>
</div>
