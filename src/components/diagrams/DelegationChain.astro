---
// Visual 3: Delegation chain as a living structure
// Node graph with time slider — chains expire and downstream nodes go red
---

<div class="reveal my-12 md:my-16">
  <div class="rounded-2xl border border-border overflow-hidden" style="background: rgba(11,11,17,0.6);">
    <canvas
      id="delegation-chain"
      class="w-full"
      style="height: 320px;"
    ></canvas>
    <div class="px-6 pb-5 pt-2">
      <input
        id="dc-slider"
        type="range" min="0" max="100" value="30"
        class="w-full accent-signal h-1 bg-border rounded-full appearance-none cursor-pointer"
      />
      <div class="flex justify-between text-[9px] text-text-tertiary font-mono mt-1">
        <span>1 May</span><span>7 May</span><span>14 May</span><span>21 May</span><span>28 May</span>
      </div>
    </div>
  </div>
  <p class="text-text-tertiary text-xs mt-3 text-center italic">
    Authority is not owned in isolation. It is inherited through chains that can expire.
  </p>
</div>

<script>
const canvas = document.getElementById('delegation-chain') as HTMLCanvasElement;
const slider = document.getElementById('dc-slider') as HTMLInputElement;

if (canvas && slider) {
  const ctx = canvas.getContext('2d')!;

  const VALID = [74, 222, 128];
  const EXPIRED = [239, 68, 68];
  const VIOLET = [167, 139, 250];
  const DIM = [100, 100, 120];

  interface ChainNode {
    x: number; y: number;
    label: string;
    sublabel: string;
    grantStart: number; grantEnd: number; // 0-100
    upstream: number | null;
  }

  function buildNodes(w: number, h: number): ChainNode[] {
    const cx = w / 2;
    const cy = h / 2;
    const spread = Math.min(w * 0.35, 220);
    return [
      { x: cx, y: cy - 100, label: 'Board', sublabel: 'Root authority', grantStart: 0, grantEnd: 100, upstream: null },
      { x: cx, y: cy - 20, label: 'Programme Director', sublabel: 'Delegated at: 3 May', grantStart: 8, grantEnd: 75, upstream: 0 },
      { x: cx - spread * 0.7, y: cy + 70, label: 'Regional Lead', sublabel: 'Delegated at: 7 May', grantStart: 20, grantEnd: 65, upstream: 1 },
      { x: cx + spread * 0.7, y: cy + 70, label: 'Temporary Approver', sublabel: 'Delegated at: 14 May', grantStart: 40, grantEnd: 60, upstream: 2 },
    ];
  }

  let nodes = buildNodes(canvas.clientWidth, canvas.clientHeight);
  let hoverNode = -1;

  function resize() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    nodes = buildNodes(canvas.clientWidth, canvas.clientHeight);
  }

  function isValid(node: ChainNode, t: number): boolean {
    if (t < node.grantStart || t > node.grantEnd) return false;
    if (node.upstream !== null) return isValid(nodes[node.upstream], t);
    return true;
  }

  function render() {
    const w = canvas.clientWidth;
    const h = canvas.clientHeight;
    const t = parseInt(slider.value);

    ctx.clearRect(0, 0, w, h);

    // Edges
    for (const node of nodes) {
      if (node.upstream === null) continue;
      const parent = nodes[node.upstream];
      const valid = isValid(node, t);
      const parentValid = isValid(parent, t);
      const edgeValid = valid && parentValid;
      const [r, g, b] = edgeValid ? VALID : (t > node.grantEnd || !parentValid) ? EXPIRED : DIM;

      ctx.beginPath();
      ctx.moveTo(parent.x, parent.y);
      ctx.lineTo(node.x, node.y);
      ctx.strokeStyle = `rgba(${r},${g},${b},${edgeValid ? 0.4 : 0.15})`;
      ctx.lineWidth = edgeValid ? 1.5 : 0.8;
      ctx.stroke();

      // Time window label on edge
      const mx = (parent.x + node.x) / 2;
      const my = (parent.y + node.y) / 2;
      const dateStart = Math.round(node.grantStart / 100 * 28) + 1;
      const dateEnd = Math.round(node.grantEnd / 100 * 28) + 1;
      ctx.font = '400 8px "JetBrains Mono", monospace';
      ctx.fillStyle = `rgba(${r},${g},${b},0.4)`;
      ctx.textAlign = 'center';
      ctx.fillText(`${dateStart}–${dateEnd} May`, mx + 15, my - 4);
    }

    // Nodes
    for (let i = 0; i < nodes.length; i++) {
      const node = nodes[i];
      const valid = isValid(node, t);
      const selfExpired = t > node.grantEnd;
      const [r, g, b] = valid ? VALID : selfExpired ? EXPIRED : DIM;
      const radius = i === 0 ? 24 : 20;

      // Glow
      const grad = ctx.createRadialGradient(node.x, node.y, 0, node.x, node.y, radius * 2.5);
      grad.addColorStop(0, `rgba(${r},${g},${b},${valid ? 0.12 : 0.04})`);
      grad.addColorStop(1, `rgba(${r},${g},${b},0)`);
      ctx.fillStyle = grad;
      ctx.beginPath();
      ctx.arc(node.x, node.y, radius * 2.5, 0, Math.PI * 2);
      ctx.fill();

      // Ring
      ctx.beginPath();
      ctx.arc(node.x, node.y, radius, 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(${r},${g},${b},${valid ? 0.5 : 0.2})`;
      ctx.lineWidth = 1.5;
      ctx.stroke();
      ctx.fillStyle = `rgba(${r},${g},${b},0.06)`;
      ctx.fill();

      // Label
      ctx.font = '600 10px "Syne", system-ui';
      ctx.fillStyle = `rgba(232,232,240,${valid ? 0.85 : 0.3})`;
      ctx.textAlign = 'center';
      ctx.fillText(node.label, node.x, node.y - 2);

      // Status
      ctx.font = '400 8px "Inter", system-ui';
      const statusText = valid ? 'Valid' : selfExpired ? 'Expired' : 'Upstream lapsed';
      ctx.fillStyle = `rgba(${r},${g},${b},0.6)`;
      ctx.fillText(statusText, node.x, node.y + 11);

      // Hover tooltip
      if (i === hoverNode) {
        const tx = node.x + radius + 15;
        const ty = node.y - 30;
        ctx.fillStyle = 'rgba(11,11,17,0.9)';
        ctx.beginPath();
        ctx.roundRect(tx, ty, 200, 72, 6);
        ctx.fill();
        ctx.strokeStyle = 'rgba(255,255,255,0.08)';
        ctx.lineWidth = 1;
        ctx.stroke();

        ctx.font = '600 9px "Syne", system-ui';
        ctx.fillStyle = 'rgba(232,232,240,0.8)';
        ctx.textAlign = 'left';
        ctx.fillText(`Actor: ${node.label}`, tx + 10, ty + 16);
        ctx.font = '400 8px "Inter", system-ui';
        ctx.fillStyle = 'rgba(232,232,240,0.4)';
        ctx.fillText(node.sublabel, tx + 10, ty + 30);
        ctx.fillText(`Current state: ${statusText}`, tx + 10, ty + 44);
        if (!valid && !selfExpired) {
          ctx.fillStyle = 'rgba(239,68,68,0.6)';
          ctx.fillText('Reason: upstream delegation window closed', tx + 10, ty + 58);
        }
      }
    }
  }

  canvas.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    hoverNode = -1;
    for (let i = 0; i < nodes.length; i++) {
      const dx = nodes[i].x - mx;
      const dy = nodes[i].y - my;
      if (dx * dx + dy * dy < 600) { hoverNode = i; break; }
    }
    render();
  });

  canvas.addEventListener('mouseleave', () => { hoverNode = -1; render(); });
  slider.addEventListener('input', render);

  resize();
  window.addEventListener('resize', () => { resize(); render(); });
  render();
}
</script>
