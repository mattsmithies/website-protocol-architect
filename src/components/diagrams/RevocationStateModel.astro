---
// Figure 5: Revocation state model
// State machine for a digital identity credential. Separate states for
// active, deleted by holder, suspended, revoked, expired, recovered, and reissued.
// Tap a state or a transition for its semantics.
---

<div class="reveal my-12 md:my-16">
  <div class="rounded-2xl border border-border overflow-hidden" style="background: rgba(11,11,17,0.6);">
    <div class="p-6 md:p-8">

      <div class="mb-5">
        <p class="text-text-tertiary text-xs font-semibold tracking-[0.2em] uppercase mb-1">Credential lifecycle</p>
        <h3 class="text-text-primary font-display font-bold text-lg tracking-tight">Revocation state model</h3>
      </div>

      <canvas id="rsm-canvas" class="w-full" style="height: 520px; cursor: pointer;" role="img" aria-label="State machine showing separate states for active, deleted by holder, suspended, revoked, expired, recovered, and reissued credentials, with transitions between them."></canvas>

      <div id="rsm-detail" class="mt-4 p-4 rounded-lg border border-border transition-all duration-300" style="opacity: 0; background: rgba(11,11,17,0.8);">
        <p id="rsm-detail-label" class="text-[11px] font-semibold tracking-[0.2em] uppercase mb-2"></p>
        <p id="rsm-detail-name" class="text-text-primary text-sm mb-2" style="font-family:'Syne',system-ui; font-weight:600;"></p>
        <p id="rsm-detail-desc" class="text-sm text-text-secondary"></p>
      </div>

    </div>
  </div>
  <p class="text-text-tertiary text-xs mt-3 text-center italic">
    Deletion, suspension, and revocation are not the same event. Each transition should carry a legible reason, a responsible authority, a time, and a route to challenge.
  </p>
</div>

<script>
interface State {
  id: string;
  label: string;
  kind: 'state' | 'holder' | 'admin' | 'terminal' | 'recovery';
  x: number; // fraction of width
  y: number; // fraction of height
  desc: string;
}

interface Transition {
  from: string;
  to: string;
  label: string;
  desc: string;
  kind: 'holder' | 'admin' | 'auto';
}

const canvas = document.getElementById('rsm-canvas') as HTMLCanvasElement;
const detail = document.getElementById('rsm-detail')!;
const detailLabel = document.getElementById('rsm-detail-label')!;
const detailName = document.getElementById('rsm-detail-name')!;
const detailDesc = document.getElementById('rsm-detail-desc')!;

if (canvas) {
  const ctx = canvas.getContext('2d')!;

  const GREEN: [number, number, number] = [74, 222, 128];
  const AMBER: [number, number, number] = [245, 158, 11];
  const RED: [number, number, number] = [239, 68, 68];
  const BLUE: [number, number, number] = [56, 189, 248];
  const VIOLET: [number, number, number] = [167, 139, 250];
  const DIM: [number, number, number] = [160, 160, 180];

  const KIND_COLOR: Record<State['kind'], [number, number, number]> = {
    state: GREEN,
    holder: BLUE,
    admin: AMBER,
    terminal: RED,
    recovery: VIOLET,
  };

  const states: State[] = [
    { id: 'active',    label: 'Active',            kind: 'state',    x: 0.50, y: 0.18, desc: 'Credential is valid and checkable. Verification succeeds. Holder controls presentation and disclosure.' },
    { id: 'deleted',   label: 'Deleted by holder', kind: 'holder',   x: 0.18, y: 0.40, desc: 'Removed from the holder device at the person’s request. Does not affect administrative validity. Can be reissued on request.' },
    { id: 'suspended', label: 'Suspended',         kind: 'admin',    x: 0.50, y: 0.46, desc: 'Temporary hold pending review. No new checks succeed. Must carry a reason, a responsible authority, and a route to challenge.' },
    { id: 'expired',   label: 'Expired',           kind: 'state',    x: 0.82, y: 0.40, desc: 'Reached end of validity window. Automatic, not punitive. Holder receives notice and a path to renewal.' },
    { id: 'revoked',   label: 'Revoked',           kind: 'terminal', x: 0.50, y: 0.75, desc: 'Administrative termination, limited to circumstances such as confirmed fraudulent use. Requires due process and an appeal route.' },
    { id: 'recovered', label: 'Recovered',         kind: 'recovery', x: 0.18, y: 0.75, desc: 'Restored after lost or stolen device, or after a suspension review. Returns the credential to active state on a new device.' },
    { id: 'reissued',  label: 'Reissued',          kind: 'recovery', x: 0.82, y: 0.75, desc: 'A fresh credential issued after expiry, revocation appeal, or deletion. Previous credential remains in its terminal state on the record.' },
  ];

  const transitions: Transition[] = [
    { from: 'active',    to: 'deleted',   kind: 'holder', label: 'Holder deletes',    desc: 'The person deletes the credential from their device. The administrative record is unchanged.' },
    { from: 'active',    to: 'suspended', kind: 'admin',  label: 'Admin suspends',    desc: 'Under a defined reason, an authority places the credential on hold pending review. Must be appealable.' },
    { from: 'active',    to: 'expired',   kind: 'auto',   label: 'Validity ends',     desc: 'The credential reaches the end of its validity window. Transition is automatic and predictable.' },
    { from: 'suspended', to: 'active',    kind: 'admin',  label: 'Review clears',     desc: 'Review finds no grounds for continued action. The credential returns to active with a record of the review.' },
    { from: 'suspended', to: 'revoked',   kind: 'admin',  label: 'Review confirms',   desc: 'Review confirms grounds for revocation. The credential moves to a terminal state with the reason on record.' },
    { from: 'revoked',   to: 'reissued',  kind: 'admin',  label: 'Successful appeal', desc: 'After an appeal or correction, a new credential is issued. The previous credential stays revoked in the record.' },
    { from: 'deleted',   to: 'recovered', kind: 'holder', label: 'Holder recovers',   desc: 'The person restores the credential on a new device. Requires recovery proof, not re-enrolment from scratch.' },
    { from: 'expired',   to: 'reissued',  kind: 'auto',   label: 'Renewal',           desc: 'The holder renews the credential. A new credential replaces the expired one in active use.' },
  ];

  let activeStateIdx = -1;
  let activeTransIdx = -1;
  let animId = 0;
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function resize() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  function getLayout() {
    const w = canvas.clientWidth;
    const h = canvas.clientHeight;
    const isNarrow = w < 500;
    const padX = isNarrow ? 20 : 40;
    const padY = 40;
    const usableW = w - padX * 2;
    const usableH = h - padY * 2;
    const nodeHalfW = isNarrow ? 60 : 75;
    const nodeHalfH = isNarrow ? 22 : 24;
    return { w, h, isNarrow, padX, padY, usableW, usableH, nodeHalfW, nodeHalfH };
  }

  function statePos(s: State) {
    const { padX, padY, usableW, usableH } = getLayout();
    return { x: padX + s.x * usableW, y: padY + s.y * usableH };
  }

  function drawRoundedRect(x: number, y: number, w: number, h: number, r: number) {
    ctx.beginPath();
    ctx.roundRect(x, y, w, h, r);
  }

  function drawArrow(x1: number, y1: number, x2: number, y2: number, color: [number, number, number], alpha: number, dashed: boolean) {
    const [r, g, b] = color;
    ctx.beginPath();
    ctx.moveTo(x1, y1);
    ctx.lineTo(x2, y2);
    ctx.strokeStyle = `rgba(${r},${g},${b},${alpha})`;
    ctx.lineWidth = 1.2;
    if (dashed) ctx.setLineDash([5, 4]);
    ctx.stroke();
    ctx.setLineDash([]);

    // Arrowhead
    const angle = Math.atan2(y2 - y1, x2 - x1);
    const head = 7;
    ctx.beginPath();
    ctx.moveTo(x2, y2);
    ctx.lineTo(x2 - head * Math.cos(angle - Math.PI / 7), y2 - head * Math.sin(angle - Math.PI / 7));
    ctx.moveTo(x2, y2);
    ctx.lineTo(x2 - head * Math.cos(angle + Math.PI / 7), y2 - head * Math.sin(angle + Math.PI / 7));
    ctx.strokeStyle = `rgba(${r},${g},${b},${alpha + 0.15})`;
    ctx.lineWidth = 1.2;
    ctx.stroke();
  }

  function endpointOnBorder(from: { x: number; y: number }, to: { x: number; y: number }, halfW: number, halfH: number, outward = true) {
    // Compute where a line from `from` meets the rectangle border of node `to`.
    const dx = (outward ? to.x - from.x : from.x - to.x);
    const dy = (outward ? to.y - from.y : from.y - to.y);
    const scaleX = halfW / Math.abs(dx || 0.0001);
    const scaleY = halfH / Math.abs(dy || 0.0001);
    const scale = Math.min(scaleX, scaleY);
    const ox = (outward ? to.x : from.x) - dx * scale;
    const oy = (outward ? to.y : from.y) - dy * scale;
    return { x: ox, y: oy };
  }

  function transitionColor(kind: Transition['kind']): [number, number, number] {
    if (kind === 'holder') return BLUE;
    if (kind === 'admin') return AMBER;
    return DIM;
  }

  function render(now: number) {
    const { w, h, isNarrow, nodeHalfW, nodeHalfH } = getLayout();
    const t = now * 0.001;
    ctx.clearRect(0, 0, w, h);

    // Draw transitions first (behind nodes)
    const posMap = new Map(states.map(s => [s.id, statePos(s)]));
    for (let ti = 0; ti < transitions.length; ti++) {
      const tr = transitions[ti];
      const pFrom = posMap.get(tr.from)!;
      const pTo = posMap.get(tr.to)!;
      const color = transitionColor(tr.kind);
      const active = ti === activeTransIdx;
      const alpha = active ? 0.75 : 0.3;
      const dashed = tr.kind === 'holder';

      const start = endpointOnBorder(pFrom, pTo, nodeHalfW, nodeHalfH, false);
      const end = endpointOnBorder(pFrom, pTo, nodeHalfW, nodeHalfH, true);
      drawArrow(start.x, start.y, end.x, end.y, color, alpha, dashed);

      // Label at midpoint
      const mx = (start.x + end.x) / 2;
      const my = (start.y + end.y) / 2;
      ctx.font = `500 ${isNarrow ? 9 : 10}px "JetBrains Mono", monospace`;
      ctx.fillStyle = `rgba(${color[0]},${color[1]},${color[2]},${active ? 0.9 : 0.5})`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      const label = tr.label.toUpperCase();
      // Background pad so text is readable over the line
      const textW = ctx.measureText(label).width;
      ctx.fillStyle = 'rgba(11,11,17,0.9)';
      drawRoundedRect(mx - textW / 2 - 4, my - (isNarrow ? 7 : 8), textW + 8, isNarrow ? 14 : 16, 3);
      ctx.fill();
      ctx.fillStyle = `rgba(${color[0]},${color[1]},${color[2]},${active ? 0.9 : 0.55})`;
      ctx.fillText(label, mx, my);
      ctx.textBaseline = 'alphabetic';

      // Flowing particle for active transition or subtle ambient
      if (!prefersReducedMotion && active) {
        const pt = ((t * 0.5) % 1);
        const px = start.x + (end.x - start.x) * pt;
        const py = start.y + (end.y - start.y) * pt;
        ctx.beginPath();
        ctx.arc(px, py, 3, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${color[0]},${color[1]},${color[2]},0.85)`;
        ctx.fill();
      }
    }

    // Draw nodes
    for (let i = 0; i < states.length; i++) {
      const s = states[i];
      const p = posMap.get(s.id)!;
      const [r, g, b] = KIND_COLOR[s.kind];
      const active = i === activeStateIdx;

      drawRoundedRect(p.x - nodeHalfW, p.y - nodeHalfH, nodeHalfW * 2, nodeHalfH * 2, 10);
      ctx.fillStyle = `rgba(${r},${g},${b},${active ? 0.16 : 0.08})`;
      ctx.fill();
      ctx.strokeStyle = `rgba(${r},${g},${b},${active ? 0.7 : 0.4})`;
      ctx.lineWidth = active ? 1.8 : 1.2;
      ctx.stroke();

      if (active) {
        ctx.shadowColor = `rgba(${r},${g},${b},0.3)`;
        ctx.shadowBlur = 12;
        ctx.stroke();
        ctx.shadowBlur = 0;
      }

      ctx.font = `600 ${isNarrow ? 11 : 12}px "Syne", system-ui`;
      ctx.fillStyle = `rgba(232,232,240,${active ? 0.95 : 0.85})`;
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(s.label, p.x, p.y);
      ctx.textBaseline = 'alphabetic';
    }

    // Legend
    ctx.font = `500 ${isNarrow ? 9 : 10}px "JetBrains Mono", monospace`;
    ctx.textAlign = 'left';
    const legendY = h - 18;
    const items = [
      { color: BLUE, label: 'holder action' },
      { color: AMBER, label: 'admin action' },
      { color: DIM, label: 'automatic' },
    ];
    let lx = 20;
    for (const it of items) {
      ctx.fillStyle = `rgba(${it.color[0]},${it.color[1]},${it.color[2]},0.7)`;
      ctx.fillText(`● ${it.label}`, lx, legendY);
      lx += ctx.measureText(`● ${it.label}`).width + (isNarrow ? 10 : 18);
    }

    if (!prefersReducedMotion) animId = requestAnimationFrame(render);
  }

  function hitTestState(mx: number, my: number): number {
    const { nodeHalfW, nodeHalfH } = getLayout();
    for (let i = 0; i < states.length; i++) {
      const p = statePos(states[i]);
      if (Math.abs(mx - p.x) <= nodeHalfW && Math.abs(my - p.y) <= nodeHalfH) return i;
    }
    return -1;
  }

  function hitTestTransition(mx: number, my: number): number {
    const { nodeHalfW, nodeHalfH } = getLayout();
    const threshold = 10;
    for (let ti = 0; ti < transitions.length; ti++) {
      const tr = transitions[ti];
      const pFrom = statePos(states.find(s => s.id === tr.from)!);
      const pTo = statePos(states.find(s => s.id === tr.to)!);
      const start = endpointOnBorder(pFrom, pTo, nodeHalfW, nodeHalfH, false);
      const end = endpointOnBorder(pFrom, pTo, nodeHalfW, nodeHalfH, true);
      // Distance from point to segment
      const dx = end.x - start.x;
      const dy = end.y - start.y;
      const lengthSq = dx * dx + dy * dy;
      if (lengthSq < 1) continue;
      const tparam = Math.max(0, Math.min(1, ((mx - start.x) * dx + (my - start.y) * dy) / lengthSq));
      const px = start.x + tparam * dx;
      const py = start.y + tparam * dy;
      const d = Math.hypot(mx - px, my - py);
      if (d < threshold) return ti;
    }
    return -1;
  }

  function showState(i: number) {
    activeStateIdx = i;
    activeTransIdx = -1;
    const s = states[i];
    const [r, g, b] = KIND_COLOR[s.kind];
    detail.style.opacity = '1';
    detail.style.borderColor = `rgba(${r},${g},${b},0.3)`;
    detailLabel.textContent = 'State';
    detailLabel.style.color = `rgba(${r},${g},${b},0.8)`;
    detailName.textContent = s.label;
    detailDesc.textContent = s.desc;
    if (prefersReducedMotion) render(0);
  }

  function showTransition(i: number) {
    activeTransIdx = i;
    activeStateIdx = -1;
    const tr = transitions[i];
    const color = transitionColor(tr.kind);
    detail.style.opacity = '1';
    detail.style.borderColor = `rgba(${color[0]},${color[1]},${color[2]},0.3)`;
    detailLabel.textContent = 'Transition';
    detailLabel.style.color = `rgba(${color[0]},${color[1]},${color[2]},0.8)`;
    detailName.textContent = tr.label;
    detailDesc.textContent = tr.desc;
    if (prefersReducedMotion) render(0);
  }

  function hide() {
    activeStateIdx = -1;
    activeTransIdx = -1;
    detail.style.opacity = '0';
    if (prefersReducedMotion) render(0);
  }

  canvas.addEventListener('click', (e) => {
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    const sIdx = hitTestState(mx, my);
    if (sIdx >= 0) { showState(sIdx); return; }
    const tIdx = hitTestTransition(mx, my);
    if (tIdx >= 0) { showTransition(tIdx); return; }
    hide();
  });

  canvas.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    const mx = e.clientX - rect.left;
    const my = e.clientY - rect.top;
    const sIdx = hitTestState(mx, my);
    if (sIdx >= 0) { canvas.style.cursor = 'pointer'; return; }
    const tIdx = hitTestTransition(mx, my);
    canvas.style.cursor = tIdx >= 0 ? 'pointer' : 'default';
  });

  resize();
  window.addEventListener('resize', () => { resize(); if (prefersReducedMotion) render(0); });
  if (!prefersReducedMotion) {
    animId = requestAnimationFrame(render);
  } else {
    render(0);
  }
}
</script>
