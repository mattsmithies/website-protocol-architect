---
// Visual 3: Internal demand flywheel — the centrepiece
// Circular flow with adjustable sliders that strengthen or weaken the loop
---

<div class="reveal my-12 md:my-16">
  <div class="rounded-2xl border border-border overflow-hidden" style="background: rgba(11,11,17,0.6);">
    <canvas id="flywheel-canvas" class="w-full" style="height: 380px;"></canvas>

    {/* Sliders */}
    <div class="p-6 border-t border-border">
      <div class="grid grid-cols-2 md:grid-cols-3 gap-x-8 gap-y-4 max-w-2xl mx-auto">
        <div>
          <label class="text-[10px] text-text-tertiary uppercase tracking-wider block mb-1">Burned %</label>
          <input type="range" min="0" max="40" value="10" id="fw-burn" class="w-full accent-signal h-1 appearance-none cursor-pointer" />
          <span class="text-xs text-text-tertiary font-mono" id="fw-burn-val">10%</span>
        </div>
        <div>
          <label class="text-[10px] text-text-tertiary uppercase tracking-wider block mb-1">To treasury</label>
          <input type="range" min="0" max="50" value="20" id="fw-treasury" class="w-full accent-signal h-1 appearance-none cursor-pointer" />
          <span class="text-xs text-text-tertiary font-mono" id="fw-treasury-val">20%</span>
        </div>
        <div>
          <label class="text-[10px] text-text-tertiary uppercase tracking-wider block mb-1">To contributors</label>
          <input type="range" min="0" max="80" value="50" id="fw-contrib" class="w-full accent-signal h-1 appearance-none cursor-pointer" />
          <span class="text-xs text-text-tertiary font-mono" id="fw-contrib-val">50%</span>
        </div>
        <div>
          <label class="text-[10px] text-text-tertiary uppercase tracking-wider block mb-1">To passive holders</label>
          <input type="range" min="0" max="50" value="10" id="fw-passive" class="w-full accent-signal h-1 appearance-none cursor-pointer" />
          <span class="text-xs text-text-tertiary font-mono" id="fw-passive-val">10%</span>
        </div>
        <div>
          <label class="text-[10px] text-text-tertiary uppercase tracking-wider block mb-1">Exchange leakage</label>
          <input type="range" min="0" max="60" value="10" id="fw-leak" class="w-full accent-signal h-1 appearance-none cursor-pointer" />
          <span class="text-xs text-text-tertiary font-mono" id="fw-leak-val">10%</span>
        </div>
        <div class="flex items-end">
          <div id="fw-verdict" class="text-sm font-display font-bold" style="color: rgba(74,222,128,0.8);">
            Loop strengthening
          </div>
        </div>
      </div>
    </div>
  </div>
  <p class="text-text-tertiary text-xs mt-3 text-center italic">
    A token becomes durable when spend strengthens the people who make future spend worth paying.
  </p>
</div>

<script>
const canvas = document.getElementById('flywheel-canvas') as HTMLCanvasElement;
if (canvas) {
  const ctx = canvas.getContext('2d')!;

  const GREEN = [74, 222, 128];
  const BLUE = [56, 189, 248];
  const VIOLET = [167, 139, 250];
  const RED = [239, 68, 68];
  const AMBER = [245, 158, 11];

  const sliders = {
    burn: document.getElementById('fw-burn') as HTMLInputElement,
    treasury: document.getElementById('fw-treasury') as HTMLInputElement,
    contrib: document.getElementById('fw-contrib') as HTMLInputElement,
    passive: document.getElementById('fw-passive') as HTMLInputElement,
    leak: document.getElementById('fw-leak') as HTMLInputElement,
  };

  const vals = {
    burn: document.getElementById('fw-burn-val')!,
    treasury: document.getElementById('fw-treasury-val')!,
    contrib: document.getElementById('fw-contrib-val')!,
    passive: document.getElementById('fw-passive-val')!,
    leak: document.getElementById('fw-leak-val')!,
  };

  const verdict = document.getElementById('fw-verdict')!;

  function getValues() {
    const b = parseInt(sliders.burn.value);
    const t = parseInt(sliders.treasury.value);
    const c = parseInt(sliders.contrib.value);
    const p = parseInt(sliders.passive.value);
    const l = parseInt(sliders.leak.value);
    vals.burn.textContent = b + '%';
    vals.treasury.textContent = t + '%';
    vals.contrib.textContent = c + '%';
    vals.passive.textContent = p + '%';
    vals.leak.textContent = l + '%';
    return { burn: b, treasury: t, contrib: c, passive: p, leak: l };
  }

  function resize() {
    const dpr = Math.min(window.devicePixelRatio || 1, 2);
    const rect = canvas.getBoundingClientRect();
    canvas.width = rect.width * dpr;
    canvas.height = rect.height * dpr;
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
  }

  interface Stage { x: number; y: number; label: string; sublabel: string; }

  function getStages(w: number, h: number): Stage[] {
    const cx = w / 2;
    const cy = h / 2;
    const rx = Math.min(w * 0.32, 150);
    const ry = Math.min(h * 0.34, 130);
    const angles = [-Math.PI / 2, -Math.PI / 10, Math.PI / 3, Math.PI * 0.8, Math.PI * 1.3];
    const labels = ['Acquire token', 'Spend for\nnetwork action', 'Redistribute to\ncontributors', 'Network quality\nimproves', 'More usage\nattracts buyers'];
    const sublabels = ['Demand enters', 'Required action', 'Value routing', 'Supply strengthens', 'Loop closes'];
    return angles.map((a, i) => ({
      x: cx + Math.cos(a) * rx,
      y: cy + Math.sin(a) * ry,
      label: labels[i],
      sublabel: sublabels[i],
    }));
  }

  let animId = 0;

  function render(now: number) {
    const w = canvas.clientWidth;
    const h = canvas.clientHeight;
    const t = now * 0.001;
    const v = getValues();

    // Health score: contributors vs leakage/passive
    const health = (v.contrib * 1.5 - v.leak * 2 - v.passive * 0.8 - v.burn * 0.3) / 100;
    const clamped = Math.max(-1, Math.min(1, health));

    // Verdict
    if (clamped > 0.2) {
      verdict.textContent = 'Loop strengthening';
      verdict.style.color = 'rgba(74,222,128,0.8)';
    } else if (clamped > -0.1) {
      verdict.textContent = 'Loop stalling';
      verdict.style.color = 'rgba(245,158,11,0.8)';
    } else {
      verdict.textContent = 'Loop failing';
      verdict.style.color = 'rgba(239,68,68,0.8)';
    }

    ctx.clearRect(0, 0, w, h);
    const stages = getStages(w, h);

    // Health-based colors
    const loopR = clamped > 0 ? GREEN : clamped > -0.3 ? AMBER : RED;

    // Draw edges (circle)
    for (let i = 0; i < stages.length; i++) {
      const a = stages[i];
      const b = stages[(i + 1) % stages.length];
      const [r, g, bl] = loopR;
      const alpha = 0.12 + Math.max(0, clamped) * 0.15;

      ctx.beginPath();
      ctx.moveTo(a.x, a.y);
      ctx.lineTo(b.x, b.y);
      ctx.strokeStyle = `rgba(${r},${g},${bl},${alpha})`;
      ctx.lineWidth = 1.5 + Math.max(0, clamped) * 1.5;
      ctx.stroke();

      // Particles
      const speed = 0.15 + Math.max(0, clamped) * 0.2;
      for (let p = 0; p < 2; p++) {
        const pt = ((t * speed + i * 0.2 + p * 0.5) % 1);
        const px = a.x + (b.x - a.x) * pt;
        const py = a.y + (b.y - a.y) * pt;
        ctx.beginPath();
        ctx.arc(px, py, 2, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${r},${g},${bl},${0.3 + Math.max(0, clamped) * 0.4})`;
        ctx.fill();
      }
    }

    // Nodes
    for (const stage of stages) {
      const [r, g, bl] = loopR;
      const grad = ctx.createRadialGradient(stage.x, stage.y, 0, stage.x, stage.y, 35);
      grad.addColorStop(0, `rgba(${r},${g},${bl},0.08)`);
      grad.addColorStop(1, `rgba(${r},${g},${bl},0)`);
      ctx.fillStyle = grad;
      ctx.beginPath();
      ctx.arc(stage.x, stage.y, 35, 0, Math.PI * 2);
      ctx.fill();

      ctx.beginPath();
      ctx.arc(stage.x, stage.y, 14, 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(${r},${g},${bl},0.35)`;
      ctx.lineWidth = 1.5;
      ctx.stroke();

      // Multi-line label
      ctx.font = '600 9px "Syne", system-ui';
      ctx.fillStyle = 'rgba(232,232,240,0.7)';
      ctx.textAlign = 'center';
      const lines = stage.label.split('\n');
      lines.forEach((line, li) => {
        ctx.fillText(line, stage.x, stage.y - 22 - (lines.length - 1 - li) * 11);
      });

      ctx.font = '400 8px "Inter", system-ui';
      ctx.fillStyle = `rgba(${r},${g},${bl},0.4)`;
      ctx.fillText(stage.sublabel, stage.x, stage.y + 24);
    }

    animId = requestAnimationFrame(render);
  }

  resize();
  window.addEventListener('resize', resize);
  Object.values(sliders).forEach(s => s.addEventListener('input', () => {}));

  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    animId = requestAnimationFrame(render);
  } else { render(5000); }
}
</script>
