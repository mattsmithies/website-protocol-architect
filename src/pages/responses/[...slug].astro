---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import ArticleMasthead from '../../components/ArticleMasthead.astro';
import { estimateReadTimeFromFile } from '../../utils/readTime';
import '../../styles/global.css';

export async function getStaticPaths() {
  const responses = await getCollection('responses');
  return responses.map((response) => ({
    params: { slug: response.id },
    props: { response },
  }));
}

const { response } = Astro.props;
const { Content } = await render(response);
const readTime = estimateReadTimeFromFile('src/content/responses', response.id);

const siteURL = Astro.site ?? new URL('https://mattsmithies.com');
const pageURL = new URL(`/responses/${response.id}/`, siteURL).toString();
const ogImage = `/og/${response.id}.png`;
const absoluteOgImage = new URL(ogImage, siteURL).toString();

const published = response.data.publishedDate?.toISOString();
const modified = response.data.modifiedDate?.toISOString() ?? published;
const displayDate = response.data.publishedDate
  ? response.data.publishedDate.toISOString().split('T')[0]
  : undefined;

const jsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: response.data.title,
  description: response.data.summary,
  image: absoluteOgImage,
  url: pageURL,
  mainEntityOfPage: pageURL,
  inLanguage: 'en-GB',
  author: {
    '@type': 'Person',
    name: 'Matt Smithies',
    url: siteURL.toString(),
  },
  publisher: {
    '@type': 'Person',
    name: 'Matt Smithies',
    url: siteURL.toString(),
  },
  ...(published && { datePublished: published }),
  ...(modified && { dateModified: modified }),
  ...(response.data.tags && { keywords: response.data.tags.join(', ') }),
  ...(response.data.consultationUrl && {
    about: {
      '@type': 'CreativeWork',
      name: 'Making public services work for you with your digital identity',
      url: response.data.consultationUrl,
    },
    citation: {
      '@type': 'CreativeWork',
      name: 'Making public services work for you with your digital identity — GOV.UK consultation',
      url: response.data.consultationUrl,
    },
  }),
  isPartOf: {
    '@type': 'Series',
    name: 'Responses',
    url: new URL('/#responses', siteURL).toString(),
  },
};
---

<Layout
  title={`${response.data.title} — Matt Smithies`}
  description={response.data.summary}
  ogImage={ogImage}
  ogType="article"
  publishedTime={published}
  modifiedTime={modified}
  author="Matt Smithies"
  section="Responses"
  tags={response.data.tags}
  jsonLd={jsonLd}
>
  <Nav />
  <main>
    <article class="px-6 pb-32">

      <ArticleMasthead
        kind="response"
        number={response.data.order}
        category="Public Intervention"
        title={response.data.title}
        lede={response.data.summary}
        date={response.data.date}
        publishedDate={response.data.publishedDate}
        readTime={readTime}
        backHref="/#responses"
      />

      <div class="max-w-3xl mx-auto mt-10 md:mt-14">

        <div class="reveal mb-12 space-y-5 text-text-tertiary text-base leading-relaxed">
          <p>
            This response forms part of an ongoing public record of submissions on digital identity, authority, verification, and public digital infrastructure.
          </p>
          {response.data.framing && (
            <p>
              {response.data.framing}
            </p>
          )}
        </div>

        {response.data.consultationQuestions && response.data.consultationQuestions.length > 0 && (
          <div class="reveal mb-14 rounded-xl border border-border/60 p-5 md:p-6" style="background: rgba(11,11,17,0.55);">
            <p class="text-text-tertiary text-[11px] font-semibold tracking-[0.24em] uppercase mb-4">
              Consultation questions addressed
            </p>
            <ul class="divide-y divide-border/40">
              {response.data.consultationQuestions.map((q) => (
                <li class="flex items-baseline gap-4 py-2.5 text-sm">
                  <span class="font-mono text-text-tertiary tracking-tight shrink-0 w-[5.5rem]">
                    {q.ref}
                  </span>
                  <span class="text-text-secondary leading-snug">
                    {q.label}
                  </span>
                </li>
              ))}
            </ul>
          </div>
        )}

        <div class="reveal prose-custom space-y-6 text-text-secondary text-lg leading-relaxed">
          <Content />
        </div>

      </div>
    </article>
  </main>
  <Footer />
</Layout>

<script>
  import { initScrollAnimations } from '../../scripts/scroll-animations';
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initScrollAnimations);
  } else {
    initScrollAnimations();
  }
</script>
